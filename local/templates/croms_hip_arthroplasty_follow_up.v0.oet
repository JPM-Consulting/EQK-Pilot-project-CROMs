    <definition archetype_id="openEHR-EHR-COMPOSITION.report.v1" concept_name="Report" name="CROMS hip arthroplasty follow up" xmlns:tem="openEHR/v1/Template" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="tem:COMPOSITION">
        <Content archetype_id="openEHR-EHR-OBSERVATION.orthopaedic_hip_clinical_follow_up.v0" concept_name="Orthopaedic hip clinical follow-up" max="1" name="Hip clinical follow-up including HHS" path="/content" xsi:type="tem:OBSERVATION">
            <Rule max="1" name="Point in time" path="/data[at0001]/events[at0002]">
                <eventConstraint>
                    <allowedType>PointInTime</allowedType>
                </eventConstraint>
            </Rule>
        </Content>
        <Content archetype_id="openEHR-EHR-EVALUATION.orthopaedic_clinical_follow_up.v0" concept_name="Orthopaedic clinical follow-up" max="1" name="Orthopaedic clinical background and follow-up" path="/content" xsi:type="tem:EVALUATION"/>
        <Content archetype_id="openEHR-EHR-OBSERVATION.hip_prosthesis_xray_follow_up.v0" max="1" path="/content" xsi:type="tem:OBSERVATION">
            <Rule max="1" name="Point in time" path="/data[at0001]/events[at0002]">
                <eventConstraint>
                    <allowedType>PointInTime</allowedType>
                </eventConstraint>
            </Rule>
        </Content>
    </definition>
