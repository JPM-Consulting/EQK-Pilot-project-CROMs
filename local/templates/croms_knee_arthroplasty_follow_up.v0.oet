        <Content archetype_id="openEHR-EHR-EVALUATION.orthopaedic_knee_clinical_follow_up.v0" concept_name="Orthopaedic knee clinical follow-up" max="1" name="Knee clinical follow-up" path="/content" xsi:type="tem:EVALUATION"/>
