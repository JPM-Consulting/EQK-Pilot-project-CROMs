					description = <"">
				>
				["at0010"] = <
					text = <"Standing">
					description = <"">
				>
				["at0011"] = <
					text = <"HKA angle">
					description = <"Hip-knee-ankle angle measured on a weight-bearing full-length lower limb radiograph.">
				>
				["at0012"] = <
					text = <"Prior implant status">
					description = <"Presence or absence of prior implants relevant to the knee arthroplasty radiographic follow-up.">
				>
				["at0013"] = <
					text = <"Present">
					description = <"">
				>
