ontology
	term_definitions = <
		["en"] = <
			items = <
				["at0000"] = <
					text = <"Knee arthroplasty X-ray follow-up">
					description = <"Radiographic follow-up assessment after knee arthroplasty, including implant alignment, component-specific radiolucent line measurements, patellar component zones, and patellar tracking and morphology measurements.">
				>
				["at0001"] = <
					text = <"History">
					description = <"@ internal @">
				>
				["at0002"] = <
					text = <"Any event">
					description = <"@ internal @">
				>
				["at0003"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0004"] = <
					text = <"X-ray date">
					description = <"Date on which the X-ray examination was performed, if recorded separately from the observation event time.">
				>
				["at0005"] = <
					text = <"Knee side">
					description = <"">
				>
				["at0006"] = <
					text = <"Left">
					description = <"Left knee.">
				>
				["at0007"] = <
					text = <"Right">
					description = <"Right knee.">
				>
				["at0008"] = <
					text = <"Patient position during imaging">
					description = <"">
				>
				["at0009"] = <
