									ELEMENT[at0004] occurrences matches {0..1} matches {    -- X-ray date
										value matches {
											DV_DATE matches {*}
										}
									}
									ELEMENT[at0012] occurrences matches {0..1} matches {    -- Prior implant status
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0013,    -- Present
													at0014,    -- Absent
