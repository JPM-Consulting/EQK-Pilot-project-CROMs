		["fr"] = <
			items = <
				["at0000"] = <
					text = <"Suivi radiographique d’arthroplastie du genou">
					description = <"Évaluation radiographique de suivi après arthroplastie du genou, incluant l’alignement de l’implant, les mesures des lignes radiotransparentes propres à chaque composant, les zones du composant rotulien ainsi que les mesures du centrage et de la morphologie rotuliens.">
				>
				["at0001"] = <
					text = <"Historique">
					description = <"@ internal @">
				>
				["at0002"] = <
					text = <"Tout événement">
					description = <"@ internal @">
				>
				["at0003"] = <
					text = <"Arborescence">
					description = <"@ internal @">
				>
				["at0004"] = <
					text = <"Date de radiographie">
					description = <"Date à laquelle l’examen radiographique a été réalisé, si elle est enregistrée séparément de l’heure de l’événement d’observation.">
				>
				["at0005"] = <
					text = <"Côté du genou">
					description = <"">
				>
				["at0006"] = <
					text = <"Gauche">
					description = <"Genou gauche.">
				>
				["at0007"] = <
