	term_definitions = <
		["en"] = <
			items = <
				["at0000"] = <
					text = <"Hip prosthesis X-ray follow-up">
					description = <"Structured radiographic follow-up findings for a hip prosthesis, including cup, stem, radiolucency, ossification and angular measurements.">
