	term_definitions = <
		["en"] = <
			items = <
				["at0000"] = <
					text = <"Orthopaedic knee clinical follow-up">
					description = <"A structured clinician-reported assessment for orthopaedic knee follow-up, including knee arthroplasty context, pain, range of motion, stability, flexion contracture, extension lag, clinical alignment, functional ability and the patient's physical condition in relation to age.">
				>
				["at0001"] = <
					text = <"Item tree">
					description = <"@ internal @">
