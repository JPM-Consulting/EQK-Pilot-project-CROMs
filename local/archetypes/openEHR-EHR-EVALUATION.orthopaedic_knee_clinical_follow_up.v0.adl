		["fr"] = <
			items = <
				["at0000"] = <
					text = <"Suivi clinique orthopédique du genou">
					description = <"Évaluation structurée, rapportée par un clinicien, pour le suivi orthopédique du genou, incluant le contexte de l’arthroplastie du genou, la douleur, l’amplitude de mouvement, la stabilité, le flexum passif, le déficit d’extension active, l’alignement clinique, la capacité fonctionnelle et la condition physique du patient en fonction de l’âge.">
				>
				["at0001"] = <
					text = <"Item tree">
					description = <"@ internal @">
				>
				["at0003"] = <
					text = <"Item tree">
					description = <"@ internal @">
				>
				["at0004"] = <
					text = <"Nom du clinicien qui consulte">
					description = <"Nom du clinicien responsable de l’évaluation clinique de suivi ou qui la réalise.">
				>
				["at0005"] = <
					text = <"Contexte de l’arthroplastie du genou">
					description = <"Informations contextuelles relatives à l’arthroplastie du genou ou à la prothèse du genou, pertinentes pour cette évaluation clinique de suivi.">
				>
				["at0006"] = <
					text = <"Score genou">
					description = <"Évaluation rapportée par un clinicien de la douleur, de la mobilité, de la stabilité, du flexum passif, du déficit d’extension active et de l’alignement clinique du genou opéré ou évalué.">
				>
				["at0007"] = <
					text = <"Score fonction">
					description = <"Évaluation rapportée par un clinicien de la capacité fonctionnelle liée à la marche, à l’utilisation des escaliers, aux moyens auxiliaires et au niveau d’activité.">
				>
				["at0009"] = <
					text = <"Contrôle">
					description = <"Moment de l’évaluation de suivi par rapport à l’intervention, à l’évaluation de référence ou au calendrier de suivi prévu.">
