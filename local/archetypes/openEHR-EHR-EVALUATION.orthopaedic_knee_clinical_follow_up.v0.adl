definition
	EVALUATION[at0000] matches {    -- Orthopaedic knee clinical follow-up
		data matches {
			ITEM_TREE[at0001] matches {    -- Item tree
				items cardinality matches {0..*; unordered} matches {
					CLUSTER[at0005] occurrences matches {0..1} matches {    -- Knee arthroplasty context
						items cardinality matches {1..*; unordered} matches {
							ELEMENT[at0018] occurrences matches {0..1} matches {    -- Type of prosthesis
								value matches {
									DV_CODED_TEXT matches {
										defining_code matches {
											[local::
											at0019,    -- First
											at0020,    -- First Evolution
											at0021,    -- First Sensitive
											at0022,    -- Origin
											at0023,    -- NexGen LCCK
											at0024,    -- NexGen standard
											at0025,    -- Triathlon
											at0026,    -- PUC
											at0027,    -- PFJ
											at0028]    -- Other
										}
									}
								}
							}
							ELEMENT[at0029] occurrences matches {0..1} matches {    -- Other prosthesis type
								value matches {
									DV_TEXT matches {*}
								}
							}
							ELEMENT[at0030] occurrences matches {0..1} matches {    -- Side operated or to be operated
								value matches {
									DV_CODED_TEXT matches {
										defining_code matches {
											[local::
											at0031,    -- Right
											at0032]    -- Left
										}
									}
								}
							}
						}
					}
					CLUSTER[at0006] occurrences matches {0..1} matches {    -- Knee score
						items cardinality matches {1..*; unordered} matches {
							ELEMENT[at0033] occurrences matches {0..1} matches {    -- Pain while walking
								value matches {
									DV_CODED_TEXT matches {
										defining_code matches {
											[local::
											at0034,    -- None
											at0035,    -- Mild or occasional
											at0036,    -- Moderate
											at0037]    -- Severe
										}
									}
								}
							}
							ELEMENT[at0038] occurrences matches {0..1} matches {    -- Pain on stairs
								value matches {
									DV_CODED_TEXT matches {
										defining_code matches {
											[local::
											at0039,    -- None
											at0040,    -- Mild or occasional
											at0041,    -- Moderate
											at0042]    -- Severe
										}
									}
								}
							}
							ELEMENT[at0043] occurrences matches {0..1} matches {    -- Pain at rest
								value matches {
									DV_CODED_TEXT matches {
										defining_code matches {
											[local::
											at0044,    -- None
											at0045,    -- Mild
											at0046,    -- Moderate
											at0047]    -- Severe
										}
									}
								}
							}
							CLUSTER[at0048] occurrences matches {0..1} matches {    -- Flexion-neutral-extension range of motion
								items cardinality matches {1..*; unordered} matches {
									ELEMENT[at0049] occurrences matches {0..1} matches {    -- Maximum flexion angle
										value matches {
											C_DV_QUANTITY <
												property = <[openehr::497]>
												list = <
													["1"] = <
														units = <"deg">
														units_system = <"http://unitsofmeasure.org">
														units_display_name = <"°">
													>
												>
											>
										}
									}
									ELEMENT[at0050] occurrences matches {0..1} matches {    -- Neutral position angle
										value matches {
											C_DV_QUANTITY <
												property = <[openehr::497]>
												list = <
													["1"] = <
														units = <"deg">
														units_system = <"http://unitsofmeasure.org">
														units_display_name = <"°">
													>
												>
											>
										}
									}
									ELEMENT[at0051] occurrences matches {0..1} matches {    -- Maximum extension angle
										value matches {
											C_DV_QUANTITY <
												property = <[openehr::497]>
												list = <
													["1"] = <
														units = <"deg">
														units_system = <"http://unitsofmeasure.org">
														units_display_name = <"°">
													>
												>
											>
										}
									}
								}
							}
							ELEMENT[at0052] occurrences matches {0..1} matches {    -- Medial-lateral stability in valgus/varus
								value matches {
									DV_CODED_TEXT matches {
										defining_code matches {
											[local::
											at0053,    -- 5 degrees or less
											at0054,    -- 6 to 10 degrees
											at0055]    -- More than 10 degrees
										}
									}
								}
							}
							ELEMENT[at0056] occurrences matches {0..1} matches {    -- Anterior-posterior stability
								value matches {
									DV_CODED_TEXT matches {
										defining_code matches {
											[local::
											at0057,    -- 0 to 5 mm
											at0058,    -- 6 to 10 mm
											at0059]    -- More than 10 mm
										}
									}
								}
							}
							ELEMENT[at0060] occurrences matches {0..1} matches {    -- Passive flexion contracture
								value matches {
									DV_CODED_TEXT matches {
										defining_code matches {
											[local::
											at0061,    -- 5 degrees or less
											at0062,    -- 6 to 10 degrees
											at0063,    -- 11 to 20 degrees
											at0064]    -- More than 20 degrees
										}
									}
								}
							}
							ELEMENT[at0065] occurrences matches {0..1} matches {    -- Active extension lag
								value matches {
									DV_CODED_TEXT matches {
										defining_code matches {
											[local::
											at0066,    -- None
											at0067,    -- Less than 4 degrees
											at0068,    -- 5 to 10 degrees
											at0069]    -- More than 11 degrees
										}
									}
								}
							}
							CLUSTER[at0070] occurrences matches {0..1} matches {    -- Clinical alignment
								items cardinality matches {1..*; unordered} matches {
									ELEMENT[at0071] occurrences matches {0..1} matches {    -- Valgus angle
										value matches {
											C_DV_QUANTITY <
												property = <[openehr::497]>
												list = <
													["1"] = <
														units = <"deg">
														units_system = <"http://unitsofmeasure.org">
														units_display_name = <"°">
													>
												>
											>
										}
									}
									ELEMENT[at0072] occurrences matches {0..1} matches {    -- Varus angle
										value matches {
											C_DV_QUANTITY <
												property = <[openehr::497]>
												list = <
													["1"] = <
														units = <"deg">
														units_system = <"http://unitsofmeasure.org">
														units_display_name = <"°">
													>
												>
											>
										}
									}
								}
							}
							ELEMENT[at0101] occurrences matches {0..1} matches {    -- Knee score total
								value matches {
									DV_COUNT matches {*}
								}
							}
						}
					}
					CLUSTER[at0007] occurrences matches {0..1} matches {    -- Function score
						items cardinality matches {1..*; unordered} matches {
							ELEMENT[at0078] occurrences matches {0..1} matches {    -- Walking ability
								value matches {
									DV_CODED_TEXT matches {
										defining_code matches {
											[local::
											at0079,    -- Unlimited or more than 1 hour
											at0080,    -- More than 1000 m
											at0081,    -- 500 to 1000 m or more than 30 minutes
											at0082,    -- Less than 500 m or 15 minutes or less
											at0083,    -- At home only
											at0084]    -- Impossible
										}
									}
								}
							}
							ELEMENT[at0085] occurrences matches {0..1} matches {    -- Stairs
								value matches {
									DV_CODED_TEXT matches {
										defining_code matches {
											[local::
											at0086,    -- Up and down stairs normally
											at0087,    -- Up normally, down with handrail
											at0088,    -- Up and down with handrail
											at0089]    -- Up with handrail, down impossible
										}
									}
								}
							}
							ELEMENT[at0090] occurrences matches {0..1} matches {    -- Assistive devices
								value matches {
									DV_CODED_TEXT matches {
										defining_code matches {
											[local::
											at0091,    -- None
											at0092,    -- One cane
											at0093,    -- Two canes
											at0094]    -- Two Canadian crutches or walker
										}
									}
								}
							}
							ELEMENT[at0095] occurrences matches {0..1} matches {    -- Activity level
								value matches {
									DV_CODED_TEXT matches {
										defining_code matches {
											[local::
											at0096,    -- High
											at0097,    -- Daily activity
											at0098,    -- Independent
											at0099]    -- Not independent
										}
									}
								}
							}
							ELEMENT[at0102] occurrences matches {0..1} matches {    -- Function score total
								value matches {
									DV_COUNT matches {*}
								}
							}
						}
					}
					CLUSTER[at0100] occurrences matches {0..1} matches {    -- Patient physical condition
						items cardinality matches {1..*; unordered} matches {
							ELEMENT[at0073] occurrences matches {0..1} matches {    -- Condition depending on age
								value matches {
									DV_CODED_TEXT matches {
										defining_code matches {
											[local::
											at0074,    -- Excellent
											at0075,    -- Good
											at0076,    -- Average
											at0077]    -- Poor
										}
									}
								}
							}
						}
					}
				}
			}
		}
		protocol matches {
			ITEM_TREE[at0003] matches {    -- Item tree
				items cardinality matches {0..*; unordered} matches {
					ELEMENT[at0004] occurrences matches {0..1} matches {    -- Consulting clinician name
						value matches {
							DV_TEXT matches {*}
						}
					}
					ELEMENT[at0009] occurrences matches {0..1} matches {    -- Follow-up timing
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0010,    -- Preoperative
									at0011,    -- 6 weeks
									at0012,    -- 3 months
									at0013,    -- 6 months
									at0014,    -- 1 year
									at0015,    -- 2 years
									at0016]    -- Other number of years
								}
							}
						}
					}
					ELEMENT[at0017] occurrences matches {0..1} matches {    -- Other follow-up interval in years
						value matches {
							DV_COUNT matches {*}
						}
					}
				}
			}
		}
	}

