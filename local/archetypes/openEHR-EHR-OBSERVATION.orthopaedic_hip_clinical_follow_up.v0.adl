description
	original_author = <
		["date"] = <"2026-06-01">
		["name"] = <"Jean-Pierre Messerli">
		["organisation"] = <"JPM Consulting GmbH">
		["email"] = <"jean-pierre.messerli@jpm-consulting.ch">
	>
	lifecycle_state = <"unmanaged">
	details = <
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"To record a structured clinician-reported orthopaedic follow-up assessment of the hip, particularly before or after hip arthroplasty, including Harris Hip Score items, supplementary follow-up items, range of motion, limb length comparison, physical condition and optional modified Harris Hip Score totals.">
			use = <"Use to document a point-in-time clinical assessment of the operated or assessed hip. The archetype may be used for preoperative assessment and postoperative follow-up intervals such as 6 weeks, 3 months, 6 months, 1 year, 2 years or later annual follow-up.">
			misuse = <"Not to be used as the primary record of the surgical procedure, implant registry, prosthesis inventory or medication/procedure documentation. Detailed prosthesis components should preferably be documented using dedicated procedure, device or implant archetypes if required.">
		>
		["fr"] = <
			language = <[ISO_639-1::fr]>
			purpose = <"Enregistrer une évaluation orthopédique structurée de suivi clinique de la hanche, réalisée par un clinicien, en particulier avant ou après une arthroplastie de la hanche, incluant les items du Harris Hip Score, des items complémentaires de suivi, l’amplitude de mouvement, la comparaison de la longueur des membres, la condition physique et, le cas échéant, les scores totaux du Harris Hip Score modifié.">
			copyright = <"© openEHR Foundation">
			use = <"Utiliser pour documenter une évaluation clinique ponctuelle de la hanche opérée ou évaluée. Cet archétype peut être utilisé pour l’évaluation préopératoire et pour les suivis postopératoires à 6 semaines, 3 mois, 6 mois, 1 an, 2 ans ou lors de suivis annuels ultérieurs.">
			misuse = <"Ne pas utiliser comme enregistrement principal de l’intervention chirurgicale, du registre d’implants, de l’inventaire prothétique ou de la documentation des médicaments/procédures. Les composants détaillés de la prothèse devraient, si nécessaire, être documentés de préférence au moyen d’archétypes dédiés aux procédures, dispositifs ou implants.">
		>
	>
	other_details = <
		["licence"] = <"This work is licensed under the Creative Commons Attribution-ShareAlike 4.0 International License. To view a copy of this license, visit http://creativecommons.org/licenses/by-sa/4.0/.">
		["custodian_organisation"] = <"openEHR Foundation">
		["references"] = <"Includes item structure and scoring concepts based on the Harris Hip Score and the openEHR CKM Harris Hip Score archetype.">
		["original_namespace"] = <"org.openehr">
		["original_publisher"] = <"openEHR Foundation">
		["custodian_namespace"] = <"org.openehr">
		["MD5-CAM-1.0.1"] = <"12b16f43aa08280b74aea7547542ff47">
		["build_uid"] = <"ecf0b17b-8af3-300c-aa74-bafd914c33f5">
	>

definition
	OBSERVATION[at0000] matches {    -- Orthopaedic hip clinical follow-up
		data matches {
			HISTORY[at0001] matches {    -- History
				events cardinality matches {1..*; unordered} matches {
					EVENT[at0002] occurrences matches {0..*} matches {    -- Any event
						data matches {
							ITEM_TREE[at0003] matches {    -- Tree
								items cardinality matches {0..*; unordered} matches {
									CLUSTER[at0015] occurrences matches {0..1} matches {    -- Hip arthroplasty context
										items cardinality matches {1..*; unordered} matches {
											CLUSTER[at0031] occurrences matches {0..1} matches {    -- Prosthesis summary
												items cardinality matches {1..*; unordered} matches {
													ELEMENT[at0032] occurrences matches {0..1} matches {    -- Cup / acetabular component
														value matches {
															DV_TEXT matches {*}
														}
													}
													ELEMENT[at0033] occurrences matches {0..1} matches {    -- Head
														value matches {
															DV_TEXT matches {*}
														}
													}
													ELEMENT[at0034] occurrences matches {0..1} matches {    -- Stem
														value matches {
															DV_TEXT matches {*}
														}
													}
												}
											}
											ELEMENT[at0028] occurrences matches {0..1} matches {    -- Side operated or to be operated
												value matches {
													DV_CODED_TEXT matches {
														defining_code matches {
															[local::
															at0029,    -- Right
															at0030]    -- Left
														}
													}
												}
											}
										}
									}
									CLUSTER[at0036] occurrences matches {0..1} matches {    -- Pain assessment
										items cardinality matches {1..*; unordered} matches {
											ELEMENT[at0043] occurrences matches {0..1} matches {    -- Pain
												value matches {
													44|[local::at0044],
													40|[local::at0045],
													30|[local::at0046],
													20|[local::at0047],
													10|[local::at0048],
													0|[local::at0049]
												}
											}
											ELEMENT[at0050] occurrences matches {0..*} matches {    -- Pain location
												value matches {
													DV_CODED_TEXT matches {
														defining_code matches {
															[local::
															at0051,    -- Groin
															at0052,    -- Anterior thigh
															at0053,    -- Lateral thigh
															at0054,    -- Trochanter
															at0055,    -- Knee
															at0056,    -- Lumbar / lower back
															at0057,    -- Sacroiliac
															at0058]    -- Other
														}
													}
												}
											}
											ELEMENT[at0059] occurrences matches {0..1} matches {    -- Other pain location
												value matches {
													DV_TEXT matches {*}
												}
											}
										}
									}
									CLUSTER[at0037] occurrences matches {0..1} matches {    -- Functional assessment
										items cardinality matches {1..*; unordered} matches {
											ELEMENT[at0060] occurrences matches {0..1} matches {    -- Limp
												value matches {
													11|[local::at0061],
													8|[local::at0062],
													5|[local::at0063],
													0|[local::at0064]
												}
											}
											ELEMENT[at0065] occurrences matches {0..1} matches {    -- Support devices
												value matches {
													11|[local::at0066],
													7|[local::at0067],
													5|[local::at0068],
													3|[local::at0069],
													2|[local::at0070],
													0|[local::at0071]
												}
											}
											ELEMENT[at0072] occurrences matches {0..1} matches {    -- Distance walked
												value matches {
													11|[local::at0073],
													8|[local::at0074],
													5|[local::at0075],
													2|[local::at0076],
													0|[local::at0077]
												}
											}
											ELEMENT[at0078] occurrences matches {0..1} matches {    -- Stairs
												value matches {
													4|[local::at0079],
													2|[local::at0080],
													1|[local::at0081],
													0|[local::at0082]
												}
											}
											ELEMENT[at0083] occurrences matches {0..1} matches {    -- Shoes and socks
												value matches {
													4|[local::at0084],
													2|[local::at0085],
													0|[local::at0086]
												}
											}
											ELEMENT[at0087] occurrences matches {0..1} matches {    -- Sitting
												value matches {
													5|[local::at0088],
													3|[local::at0089],
													0|[local::at0090]
												}
											}
											ELEMENT[at0091] occurrences matches {0..1} matches {    -- Public transportation
												value matches {
													1|[local::at0092],
													0|[local::at0093]
												}
											}
											ELEMENT[at0094] occurrences matches {0..1} matches {    -- Single-leg stance
												value matches {
													4|[local::at0095],
													3|[local::at0096],
													2|[local::at0097],
													1|[local::at0098]
												}
											}
											ELEMENT[at0131] occurrences matches {0..1} matches {    -- Activity
												value matches {
													4|[local::at0132],
													3|[local::at0133],
													2|[local::at0134],
													1|[local::at0135]
												}
											}
										}
									}
									CLUSTER[at0038] occurrences matches {0..1} matches {    -- Deformity assessment
										items cardinality matches {1..*; unordered} matches {
											ELEMENT[at0136] occurrences matches {0..1} matches {    -- No fixed adduction ≥ 10°
												value matches {
													DV_BOOLEAN matches {*}
												}
											}
											ELEMENT[at0137] occurrences matches {0..1} matches {    -- No fixed internal rotation ≥ 10°
												value matches {
													DV_BOOLEAN matches {*}
												}
											}
											ELEMENT[at0138] occurrences matches {0..1} matches {    -- No limb length difference ≥ 3.2 cm
												value matches {
													DV_BOOLEAN matches {*}
												}
											}
											ELEMENT[at0139] occurrences matches {0..1} matches {    -- No fixed flexion contracture ≥ 30°
												value matches {
													DV_BOOLEAN matches {*}
												}
											}
											ELEMENT[at0128] occurrences matches {0..1} matches {    -- Absence of deformity
												value matches {
													0|[local::at0129],
													4|[local::at0130]
												}
											}
										}
									}
									CLUSTER[at0039] occurrences matches {0..1} matches {    -- Range of motion
										items cardinality matches {1..*; unordered} matches {
											ELEMENT[at0104] occurrences matches {0..1} matches {    -- Flexion
												value matches {
													C_DV_QUANTITY <
														property = <[openehr::497]>
														list = <
															["1"] = <
																units = <"deg">
																units_system = <"http://unitsofmeasure.org">
																units_display_name = <"°">
															>
														>
													>
												}
											}
											ELEMENT[at0105] occurrences matches {0..1} matches {    -- Extension
												value matches {
													C_DV_QUANTITY <
														property = <[openehr::497]>
														list = <
															["1"] = <
																units = <"deg">
																units_system = <"http://unitsofmeasure.org">
																units_display_name = <"°">
															>
														>
													>
												}
											}
											ELEMENT[at0106] occurrences matches {0..1} matches {    -- Abduction
												value matches {
													C_DV_QUANTITY <
														property = <[openehr::497]>
														list = <
															["1"] = <
																units = <"deg">
																units_system = <"http://unitsofmeasure.org">
																units_display_name = <"°">
															>
														>
													>
												}
											}
											ELEMENT[at0107] occurrences matches {0..1} matches {    -- Adduction
												value matches {
													C_DV_QUANTITY <
														property = <[openehr::497]>
														list = <
															["1"] = <
																units = <"deg">
																units_system = <"http://unitsofmeasure.org">
																units_display_name = <"°">
															>
														>
													>
												}
											}
											ELEMENT[at0108] occurrences matches {0..1} matches {    -- External rotation
												value matches {
													C_DV_QUANTITY <
														property = <[openehr::497]>
														list = <
															["1"] = <
																units = <"deg">
																units_system = <"http://unitsofmeasure.org">
																units_display_name = <"°">
															>
														>
													>
												}
											}
											ELEMENT[at0109] occurrences matches {0..1} matches {    -- Internal rotation
												value matches {
													C_DV_QUANTITY <
														property = <[openehr::497]>
														list = <
															["1"] = <
																units = <"deg">
																units_system = <"http://unitsofmeasure.org">
																units_display_name = <"°">
															>
														>
													>
												}
											}
											ELEMENT[at0140] occurrences matches {0..1} matches {    -- Total range of motion score
												value matches {
													5|[local::at0141],
													4|[local::at0142],
													3|[local::at0143],
													2|[local::at0144],
													1|[local::at0145],
													0|[local::at0146]
												}
											}
										}
									}
									CLUSTER[at0040] occurrences matches {0..1} matches {    -- Limb length assessment
										items cardinality matches {1..*; unordered} matches {
											ELEMENT[at0110] occurrences matches {0..1} matches {    -- Operated limb length compared with the other limb
												value matches {
													DV_CODED_TEXT matches {
														defining_code matches {
															[local::
															at0111,    -- Same
															at0112,    -- Longer
															at0113]    -- Shorter
														}
													}
												}
											}
											ELEMENT[at0114] occurrences matches {0..1} matches {    -- Limb length difference (mm)
												value matches {
													C_DV_QUANTITY <
														property = <[openehr::122]>
														list = <
															["1"] = <
																units = <"mm">
																units_system = <"http://unitsofmeasure.org">
																units_display_name = <"mm">
															>
														>
													>
												}
											}
										}
									}
									CLUSTER[at0041] occurrences matches {0..1} matches {    -- Physical condition
										items cardinality matches {1..*; unordered} matches {
											ELEMENT[at0115] occurrences matches {0..1} matches {    -- Physical condition relative to age
												value matches {
													DV_CODED_TEXT matches {
														defining_code matches {
															[local::
															at0116,    -- Excellent
															at0117,    -- Good
															at0118,    -- Average
															at0119]    -- Poor
														}
													}
												}
											}
										}
									}
									CLUSTER[at0042] occurrences matches {0..1} matches {    -- Score summary
										items cardinality matches {1..*; unordered} matches {
											ELEMENT[at0120] occurrences matches {0..1} matches {    -- HHS total
												value matches {
													C_DV_QUANTITY <
														property = <[openehr::380]>
														list = <
															["1"] = <
																units = <"1">
																magnitude = <|0.0..100.0|>
																precision = <|2|>
															>
														>
													>
												}
											}
											ELEMENT[at0121] occurrences matches {0..1} matches {    -- mHHS raw total
												value matches {
													C_DV_QUANTITY <
														property = <[openehr::380]>
														list = <
															["1"] = <
																units = <"1">
																magnitude = <|0.0..91.0|>
																precision = <|2|>
															>
														>
													>
												}
											}
											ELEMENT[at0122] occurrences matches {0..1} matches {    -- mHHS normalised total
												value matches {
													C_DV_QUANTITY <
														property = <[openehr::380]>
														list = <
															["1"] = <
																units = <"1">
																magnitude = <|0.0..100.0|>
																precision = <|2|>
															>
														>
													>
												}
											}
											ELEMENT[at0123] occurrences matches {0..1} matches {    -- Grading
												value matches {
													DV_CODED_TEXT matches {
														defining_code matches {
															[local::
															at0124,    -- Poor
															at0125,    -- Fair
															at0126,    -- Good
															at0127]    -- Excellent
														}
													}
												}
											}
										}
									}
								}
							}
						}
					}
				}
			}
		}
		protocol matches {
			ITEM_TREE[at0004] matches {    -- Item tree
				items cardinality matches {0..*; unordered} matches {
					ELEMENT[at0005] occurrences matches {0..1} matches {    -- Consulting clinician name
						value matches {
							DV_TEXT matches {*}
						}
					}
					ELEMENT[at0006] occurrences matches {0..1} matches {    -- Follow-up timing
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0007,    -- Preoperative
									at0008,    -- 6 weeks
									at0009,    -- 3 months
									at0010,    -- 6 months
									at0011,    -- 1 year
									at0012,    -- 2 years
									at0013]    -- Other number of years
								}
							}
						}
					}
					ELEMENT[at0014] occurrences matches {0..1} matches {    -- Other follow-up interval in years
						value matches {
							DV_COUNT matches {*}
						}
					}
				}
			}
		}
	}

ontology
	term_definitions = <
		["en"] = <
			items = <
				["at0000"] = <
					text = <"Orthopaedic hip clinical follow-up">
					description = <"A structured clinician-reported assessment of hip function and clinical outcome before or after hip arthroplasty or hip surgery, including optional recording of Harris Hip Score items and total score.">
				>
				["at0001"] = <
					text = <"History">
					description = <"@ internal @">
				>
				["at0002"] = <
					text = <"Any event">
					description = <"@ internal @">
				>
				["at0003"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0004"] = <
					text = <"Item tree">
					description = <"@ internal @">
				>
				["at0005"] = <
					text = <"Consulting clinician name">
					description = <"Name of the clinician responsible for, or performing, the clinical follow-up assessment, as recorded on the form.">
				>
				["at0006"] = <
					text = <"Follow-up timing">
					description = <"Timing of the follow-up assessment in relation to surgery, baseline assessment or the planned follow-up schedule.">
				>
				["at0007"] = <
					text = <"Preoperative">
					description = <"">
				>
				["at0008"] = <
					text = <"6 weeks">
					description = <"">
				>
				["at0009"] = <
					text = <"3 months">
					description = <"">
				>
				["at0010"] = <
					text = <"6 months">
					description = <"">
				>
				["at0011"] = <
					text = <"1 year">
					description = <"">
				>
				["at0012"] = <
					text = <"2 years">
					description = <"">
				>
				["at0013"] = <
					text = <"Other number of years">
					description = <"">
				>
				["at0014"] = <
					text = <"Other follow-up interval in years">
					description = <"Number of years after surgery or baseline assessment for the follow-up timing, used when 'Other number of years' is selected.">
				>
				["at0015"] = <
					text = <"Hip arthroplasty context">
					description = <"Contextual information about the hip arthroplasty or hip prosthesis relevant to this clinical follow-up assessment.">
				>
				["at0028"] = <
					text = <"Side operated or to be operated">
					description = <"Laterality of the hip being assessed, including the hip that has been operated on or is planned for operation.">
				>
				["at0029"] = <
					text = <"Right">
					description = <"">
				>
				["at0030"] = <
					text = <"Left">
					description = <"">
				>
				["at0031"] = <
					text = <"Prosthesis summary">
					description = <"Summary information about the hip prosthesis components relevant to the follow-up assessment. This is not intended as the primary implant registry or device documentation.">
				>
				["at0032"] = <
					text = <"Cup / acetabular component">
					description = <"">
				>
				["at0033"] = <
					text = <"Head">
					description = <"">
				>
				["at0034"] = <
					text = <"Stem">
					description = <"">
				>
				["at0036"] = <
					text = <"Pain assessment">
					description = <"Assessment of pain severity and pain location related to the assessed hip.">
				>
				["at0037"] = <
					text = <"Functional assessment">
					description = <"Assessment of functional limitations related to the assessed hip, including gait, use of walking aids, walking distance, stair climbing, sitting, use of public transport and selected activities of daily living.">
				>
				["at0038"] = <
					text = <"Deformity assessment">
					description = <"Assessment of deformity criteria of the assessed hip relevant to the Harris Hip Score, including fixed deformities and limb length discrepancy.">
				>
				["at0039"] = <
					text = <"Range of motion">
					description = <"Assessment of the range of motion of the assessed hip, including flexion, extension, abduction, adduction, external rotation and internal rotation.">
				>
				["at0040"] = <
					text = <"Limb length assessment">
					description = <"Assessment of the length of the operated or assessed limb compared with the contralateral limb.">
				>
				["at0041"] = <
					text = <"Physical condition">
					description = <"Clinical assessment of the patient's overall physical condition in relation to age.">
				>
				["at0042"] = <
					text = <"Score summary">
					description = <"Summary of calculated or recorded score results for the hip clinical follow-up assessment, including Harris Hip Score and, where applicable, modified Harris Hip Score totals and grading.">
				>
				["at0043"] = <
					text = <"Pain">
					description = <"Severity or impact of pain related to the assessed hip.">
				>
				["at0044"] = <
					text = <"None, or ignores it">
					description = <"">
				>
				["at0045"] = <
					text = <"Slight, occasional, no compromise in activity">
					description = <"">
				>
				["at0046"] = <
					text = <"Mild pain, no effect on average activities, rarely moderate pain with unusual activity, may take aspirin">
					description = <"">
				>
				["at0047"] = <
					text = <"Moderate pain, tolerable but makes concessions to pain. Some limitations of ordinary activity or work. May require occasional pain medication stronger than aspirin">
					description = <"">
				>
				["at0048"] = <
					text = <"Marked pain, serious limitation of activities">
					description = <"">
				>
				["at0049"] = <
					text = <"Totally disabled, crippled, pain in bed, bedridden">
					description = <"">
				>
				["at0050"] = <
					text = <"Pain location">
					description = <"Anatomical location of pain related to the assessed hip. Multiple locations may be recorded.">
					comment = <"Supplementary question regarding HHS.">
				>
				["at0051"] = <
					text = <"Groin">
					description = <"">
				>
				["at0052"] = <
					text = <"Anterior thigh">
					description = <"">
				>
				["at0053"] = <
					text = <"Lateral thigh">
					description = <"">
				>
