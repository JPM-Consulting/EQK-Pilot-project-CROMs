					text = <"Topographie de la douleur">
					description = <"Localisation anatomique de la douleur liée à la hanche évaluée. Plusieurs localisations peuvent être enregistrées.">
					comment = <"Question complémentaire relative au HHS.">
				>
				["at0051"] = <
					text = <"Aine">
