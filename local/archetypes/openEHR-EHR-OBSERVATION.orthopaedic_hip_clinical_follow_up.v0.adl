				>
				["at0128"] = <
					text = <"Absence of deformity">
					description = <"Score component indicating whether all criteria for absence of deformity are met: less than 30 degrees of fixed flexion contracture, less than 10 degrees of fixed internal rotation in extension, less than 10 degrees of fixed adduction, and limb length discrepancy less than 3.2 cm.">
				>
				["at0129"] = <
					text = <"One or more criteria are not met.">
					description = <"One or more criteria for absence of deformity are not met.">
				>
				["at0130"] = <
					text = <"All four criteria are met.">
					description = <"All four criteria for absence of deformity are met.">
				>
				["at0131"] = <
					text = <"Activity">
					description = <"Supplementary assessment of the patient's activity level or independence in activity, recorded in addition to the Harris Hip Score items.">
					comment = <"Supplementary question regarding HHS.">
				>
				["at0132"] = <
					text = <"Significant / high">
					description = <"">
				>
				["at0133"] = <
					text = <"Daily">
					description = <"">
				>
				["at0134"] = <
					text = <"Independent">
					description = <"">
				>
				["at0135"] = <
					text = <"Not independent">
					description = <"">
				>
				["at0136"] = <
					text = <"No fixed adduction ≥ 10°">
					description = <"Indicates whether there is no fixed adduction deformity of 10 degrees or more. A value of true means that this criterion for absence of deformity is met.">
					comment = <"Supplementary question regarding HHS.">
				>
				["at0137"] = <
					text = <"No fixed internal rotation ≥ 10°">
					description = <"Indicates whether there is no fixed internal rotation deformity of 10 degrees or more. A value of true means that this criterion for absence of deformity is met.">
					comment = <"Supplementary question regarding HHS.">
				>
				["at0138"] = <
					text = <"No limb length difference ≥ 3.2 cm">
					description = <"Indicates whether there is no limb length difference of 3.2 cm or more. A value of true means that this criterion for absence of deformity is met.">
					comment = <"Supplementary question regarding HHS.">
				>
				["at0139"] = <
					text = <"No fixed flexion contracture ≥ 30°">
					description = <"Indicates whether there is no fixed flexion contracture of 30 degrees or more. A value of true means that this criterion for absence of deformity is met.">
					comment = <"Supplementary question regarding HHS.">
				>
				["at0140"] = <
					text = <"Total range of motion score">
					description = <"Ordinal score component derived from the categorised total range of motion of the assessed hip.">
