archetype (adl_version=1.4; uid=4019024a-9920-4638-82c3-1c1dc950e0dc)
	openEHR-EHR-OBSERVATION.orthopaedic_hip_clinical_follow_up.v0

concept
	[at0000]

language
	original_language = <[ISO_639-1::en]>
	translations = <
		["fr"] = <
			language = <[ISO_639-1::fr]>
			author = <
				["name"] = <"Jean-Pierre Messerli">
				["organisation"] = <"JPM Consulting GmbH">
				["email"] = <"jean-pierre.messerli@jpm-consulting.ch">
			>
		>
