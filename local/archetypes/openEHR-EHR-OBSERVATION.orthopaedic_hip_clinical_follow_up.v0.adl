				>
				["at0115"] = <
					text = <"Physical condition relative to age">
					description = <"Overall physical condition of the patient compared with the expected physical condition for their age. This is a supplementary item recorded in addition to the Harris Hip Score.">
					comment = <"Supplementary question regarding HHS.">
