		["fr"] = <
			items = <
				["at0000"] = <
					text = <"Suivi clinique orthopédique de la hanche">
					description = <"Évaluation structurée, réalisée par un clinicien, de la fonction de la hanche et du résultat clinique avant ou après une arthroplastie ou une chirurgie de la hanche, incluant l’enregistrement facultatif des items du Harris Hip Score et du score total.">
				>
				["at0001"] = <
					text = <"Historique">
					description = <"@ internal @">
				>
				["at0002"] = <
					text = <"Tout événement">
					description = <"@ internal @">
				>
				["at0003"] = <
					text = <"Arborescence">
					description = <"@ internal @">
				>
				["at0004"] = <
					text = <"Arborescence des éléments">
					description = <"@ internal @">
				>
				["at0005"] = <
					text = <"Nom du clinicien consultant">
					description = <"Nom du clinicien responsable de l’évaluation clinique de suivi, ou l’ayant réalisée, tel qu’il est documenté dans le formulaire.">
				>
				["at0006"] = <
					text = <"Moment du suivi">
					description = <"Moment de l’évaluation de suivi par rapport à l’intervention chirurgicale, à l’évaluation de référence ou au calendrier de suivi prévu.">
				>
				["at0007"] = <
					text = <"Préopératoire">
					description = <"">
				>
				["at0008"] = <
					text = <"6 semaines">
					description = <"">
				>
				["at0009"] = <
					text = <"3 mois">
					description = <"">
				>
				["at0010"] = <
					text = <"6 mois">
					description = <"">
				>
				["at0011"] = <
					text = <"1 an">
					description = <"">
				>
				["at0012"] = <
					text = <"2 ans">
					description = <"">
				>
				["at0013"] = <
					text = <"Autre nombre d’années">
					description = <"">
				>
				["at0014"] = <
					text = <"Autre intervalle de suivi en années">
					description = <"Nombre d’années après l’intervention chirurgicale ou l’évaluation de référence pour le moment du suivi, utilisé lorsque « Autre nombre d’années » est sélectionné.">
				>
				["at0015"] = <
					text = <"Contexte de l’arthroplastie de la hanche">
					description = <"Informations contextuelles sur l’arthroplastie de la hanche ou la prothèse de hanche pertinentes pour cette évaluation clinique de suivi.">
				>
				["at0028"] = <
					text = <"Côté opéré ou à opérer">
					description = <"Latéralité de la hanche évaluée, y compris la hanche qui a été opérée ou dont l’opération est prévue.">
				>
				["at0029"] = <
					text = <"Droit">
					description = <"">
				>
				["at0030"] = <
					text = <"Gauche">
					description = <"">
				>
				["at0031"] = <
					text = <"Résumé de la prothèse">
					description = <"Informations résumées sur les composants de la prothèse de hanche pertinents pour l’évaluation de suivi. Cet élément n’est pas destiné à servir de registre primaire d’implants ou de documentation principale du dispositif.">
				>
				["at0032"] = <
					text = <"Cupule / composant acétabulaire">
					description = <"">
				>
				["at0033"] = <
					text = <"Tête">
					description = <"">
				>
				["at0034"] = <
					text = <"Tige">
					description = <"">
				>
				["at0036"] = <
					text = <"Évaluation de la douleur">
					description = <"Évaluation de la sévérité et de la localisation de la douleur liée à la hanche évaluée.">
				>
				["at0037"] = <
					text = <"Évaluation fonctionnelle">
					description = <"Évaluation des limitations fonctionnelles liées à la hanche évaluée, incluant la marche, l’utilisation d’aides à la marche, le périmètre de marche, les escaliers, la position assise, l’utilisation des transports publics et certaines activités de la vie quotidienne.">
				>
				["at0038"] = <
					text = <"Évaluation de la déformation">
					description = <"Évaluation des critères de déformation de la hanche évaluée pertinents pour le Harris Hip Score, incluant les déformations fixées et l’inégalité de longueur des membres.">
				>
				["at0039"] = <
					text = <"Amplitude de mouvement">
					description = <"Évaluation de l’amplitude de mouvement de la hanche évaluée, incluant la flexion, l’extension, l’abduction, l’adduction, la rotation externe et la rotation interne.">
				>
				["at0040"] = <
					text = <"Évaluation de la longueur du membre">
					description = <"Évaluation de la longueur du membre opéré ou évalué par rapport au membre controlatéral.">
				>
				["at0041"] = <
					text = <"Condition physique">
					description = <"Évaluation clinique de la condition physique globale du patient par rapport à son âge.">
				>
				["at0042"] = <
					text = <"Résumé des scores">
					description = <"Résumé des scores calculés ou enregistrés pour l’évaluation clinique de suivi de la hanche, incluant le Harris Hip Score et, le cas échéant, les scores totaux du Harris Hip Score modifié ainsi que le classement.">
				>
				["at0043"] = <
					text = <"Douleur">
					description = <"Sévérité ou retentissement de la douleur liée à la hanche évaluée.">
				>
				["at0044"] = <
					text = <"Aucune, ou douleur ignorée">
					description = <"">
				>
				["at0045"] = <
					text = <"Légère, occasionnelle, sans limitation de l’activité">
					description = <"">
				>
				["at0046"] = <
					text = <"Douleur légère, sans effet sur les activités habituelles ; rarement douleur modérée lors d’une activité inhabituelle ; prise possible d’aspirine">
					description = <"">
				>
				["at0047"] = <
					text = <"Douleur modérée, tolérable mais nécessitant des concessions. Certaines limitations des activités ordinaires ou du travail. Peut nécessiter occasionnellement un antalgique plus fort que l’aspirine">
					description = <"">
				>
				["at0048"] = <
					text = <"Douleur marquée, limitation importante des activités">
					description = <"">
				>
