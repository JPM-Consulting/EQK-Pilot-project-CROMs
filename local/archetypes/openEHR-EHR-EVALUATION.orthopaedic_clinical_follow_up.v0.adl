					text = <"Spine">
					description = <"Associated condition affecting the spine.">
				>
				["at0077"] = <
					text = <"Elbow">
					description = <"Associated condition affecting the elbow.">
				>
				["at0078"] = <
					text = <"Other">
					description = <"Other associated orthopaedic condition not represented by the listed options.">
				>
				["at0079"] = <
