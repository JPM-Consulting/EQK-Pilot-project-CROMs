		["fr"] = <
			items = <
				["at0000"] = <
					text = <"Suivi clinique orthopédique">
					description = <"Évaluation structurée des informations de suivi clinique orthopédique, incluant les pathologies connues, les complications et les pathologies orthopédiques associées.">
				>
				["at0001"] = <
					text = <"Arborescence des éléments">
					description = <"@ internal @">
				>
				["at0002"] = <
					text = <"Extension">
					description = <"">
				>
				["at0003"] = <
					text = <"Arborescence des éléments">
					description = <"@ internal @">
				>
				["at0004"] = <
					text = <"Autres pathologies connues">
					description = <"Autres pathologies connues, comorbidités ou affections liées à un système corporel, enregistrées lors du suivi clinique.">
					comment = <"Si le statut est « Présente », au moins une autre pathologie connue doit être enregistrée.

Si le statut est « Aucune », aucune autre pathologie connue ne doit être enregistrée.

Si « Autre » est sélectionné, une description de l’autre pathologie connue doit être enregistrée.">
				>
				["at0005"] = <
					text = <"Complications systémiques">
					description = <"Complications systémiques survenues depuis la mise en place de cette prothèse.">
					comment = <"Si le statut est « Présente », au moins une complication systémique doit être enregistrée.

Si le statut est « Aucune », aucune complication systémique ne doit être enregistrée.

Enregistrer chaque complication sélectionnée comme une instance distincte de complication systémique.

Si « Autre » est sélectionné, une description de l’autre complication systémique doit être enregistrée.

Enregistrer la date de la complication lorsqu’elle est disponible.">
				>
				["at0006"] = <
					text = <"Complications locales">
					description = <"Complications locales survenues depuis la mise en place de cette prothèse.">
					comment = <"Si le statut est « Présente », au moins une complication locale doit être enregistrée.

Si le statut est « Aucune », aucune complication locale ne doit être enregistrée.

Enregistrer chaque complication sélectionnée comme une instance distincte de complication locale.

Si « Autre » est sélectionné, une description de l’autre complication locale doit être enregistrée.

Enregistrer la date ou l’année de la complication lorsqu’elle est disponible.">
				>
				["at0007"] = <
					text = <"Autres pathologies orthopédiques associées">
					description = <"Autres pathologies orthopédiques associées pertinentes pour ce suivi clinique.">
					comment = <"Si le statut est « Présente », au moins une pathologie orthopédique associée doit être enregistrée.

Si le statut est « Aucune », aucune pathologie orthopédique associée ne doit être enregistrée.

Enregistrer chaque pathologie sélectionnée comme une instance distincte d’autre pathologie orthopédique associée.

Enregistrer la latéralité, la date ou l’année, ainsi qu’une description le cas échéant.">
				>
				["at0008"] = <
					text = <"Statut des autres pathologies connues">
					description = <"Statut indiquant si d’autres pathologies connues sont enregistrées lors de ce suivi.">
					comment = <"Utiliser lorsque la présence d’autres pathologies connues est inconnue ou n’a pas été évaluée.">
				>
				["at0009"] = <
					text = <"Autre pathologie connue">
					description = <"Catégorie ou type spécifique d’autre pathologie connue enregistrée lors du suivi clinique.">
					comment = <"Élément répétable pour une utilisation en sélection multiple. Enregistrer chaque option sélectionnée comme une instance distincte. Ne pas enregistrer de valeur lorsque le statut est « Aucune ».">
				>
				["at0010"] = <
					text = <"Description d’une autre pathologie connue">
					description = <"Description en texte libre d’une autre pathologie connue non représentée par les options codées.">
					comment = <"Utiliser lorsque « Autre » est sélectionné, ou pour fournir des précisions supplémentaires sur une pathologie sélectionnée.">
				>
				["at0011"] = <
					text = <"Commentaire">
					description = <"Commentaire complémentaire en texte libre concernant le suivi clinique orthopédique.">
				>
				["at0015"] = <
					text = <"Aucune">
					description = <"Aucune autre pathologie connue n’est enregistrée lors de ce suivi.">
				>
				["at0016"] = <
					text = <"Présente">
					description = <"Une ou plusieurs autres pathologies connues sont enregistrées.">
				>
				["at0017"] = <
