definition
	EVALUATION[at0000] matches {    -- Orthopaedic clinical follow-up
		data matches {
			ITEM_TREE[at0003] matches {    -- Item tree
				items cardinality matches {0..*; unordered} matches {
					CLUSTER[at0004] occurrences matches {0..1} matches {    -- Other known conditions
						items cardinality matches {1..*; unordered} matches {
							ELEMENT[at0008] matches {    -- Other known condition status
								value matches {
									DV_CODED_TEXT matches {
										defining_code matches {
											[local::
											at0015,    -- None known
											at0016,    -- Present
											at0017]    -- Unknown or not assessed
										}
									}
								}
							}
							ELEMENT[at0009] occurrences matches {0..*} matches {    -- Other known condition
								value matches {
									DV_CODED_TEXT matches {
										defining_code matches {
											[local::
											at0018,    -- Nervous system
											at0019,    -- Gastrointestinal system
											at0020,    -- Osteoporosis
											at0021,    -- Respiratory tract
											at0022,    -- Urogenital system
											at0023,    -- Endocrine system
											at0024,    -- Cardiovascular system
											at0025,    -- Diabetes
											at0026]    -- Other
										}
									}
								}
							}
							ELEMENT[at0010] occurrences matches {0..1} matches {    -- Other known condition description
								value matches {
									DV_TEXT matches {*}
								}
							}
						}
					}
					CLUSTER[at0005] occurrences matches {0..1} matches {    -- Systemic complications
						items cardinality matches {1..*; unordered} matches {
							ELEMENT[at0027] matches {    -- Systemic complication status
								value matches {
									DV_CODED_TEXT matches {
										defining_code matches {
											[local::
											at0028,    -- None known
											at0029,    -- Present
											at0030]    -- Unknown or not assessed
										}
									}
								}
							}
							CLUSTER[at0032] occurrences matches {0..*} matches {    -- Systemic complication
								items cardinality matches {1..*; unordered} matches {
									ELEMENT[at0034] matches {    -- Systemic complication type
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0035,    -- Pulmonary embolism
													at0036,    -- Thrombophlebitis
													at0037,    -- Central nervous system
													at0038,    -- Respiratory tract
													at0039,    -- Cardiovascular system
													at0040,    -- Urological system
													at0041,    -- Gastrointestinal system
													at0042]    -- Other
												}
											}
										}
									}
									ELEMENT[at0044] occurrences matches {0..1} matches {    -- Complication date
										value matches {
											DV_DATE matches {*}
										}
									}
									ELEMENT[at0045] occurrences matches {0..1} matches {    -- Other systemic complication description
										value matches {
											DV_TEXT matches {*}
										}
									}
								}
							}
						}
					}
					CLUSTER[at0006] occurrences matches {0..1} matches {    -- Local complications
						items cardinality matches {1..*; unordered} matches {
							ELEMENT[at0046] matches {    -- Local complication status
								value matches {
									DV_CODED_TEXT matches {
										defining_code matches {
											[local::
											at0047,    -- None known
											at0048,    -- Present
											at0049]    -- Unknown or not assessed
										}
									}
								}
							}
							CLUSTER[at0050] occurrences matches {0..*} matches {    -- Local complication
								items cardinality matches {1..*; unordered} matches {
									ELEMENT[at0051] matches {    -- Local complication type
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0052,    -- Dislocation
													at0053,    -- Haematoma / seroma
													at0054,    -- Persistent drainage
													at0055,    -- Dehiscence
													at0056,    -- Neuropraxia
													at0057,    -- Loosening
													at0058,    -- Deep sepsis
													at0059,    -- Superficial sepsis
													at0060]    -- Other
												}
											}
										}
									}
									ELEMENT[at0061] occurrences matches {0..1} matches {    -- Complication date
										value matches {
											DV_DATE matches {*}
										}
									}
									ELEMENT[at0062] occurrences matches {0..1} matches {    -- Other local complication description
										value matches {
											DV_TEXT matches {*}
										}
									}
								}
							}
						}
					}
					CLUSTER[at0007] occurrences matches {0..1} matches {    -- Other associated orthopaedic conditions
						items cardinality matches {1..*; unordered} matches {
							ELEMENT[at0063] matches {    -- Other associated orthopaedic condition status
								value matches {
									DV_CODED_TEXT matches {
										defining_code matches {
											[local::
											at0064,    -- None known
											at0065,    -- Present
											at0066]    -- Unknown or not assessed
										}
									}
								}
							}
							CLUSTER[at0067] occurrences matches {0..*} matches {    -- Other associated orthopaedic condition
								items cardinality matches {1..*; unordered} matches {
									ELEMENT[at0069] matches {    -- Other associated orthopaedic condition type
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0070,    -- Contralateral knee
													at0071,    -- Ankle / foot
													at0072,    -- Wrist / hand
													at0073,    -- Opposite hip
													at0074,    -- Shoulder
													at0075,    -- Trauma
													at0076,    -- Spine
													at0077,    -- Elbow
													at0078]    -- Other
												}
											}
										}
									}
									ELEMENT[at0079] occurrences matches {0..1} matches {    -- Condition date
										value matches {
											DV_DATE matches {*}
										}
									}
									ELEMENT[at0080] occurrences matches {0..1} matches {    -- Condition laterality
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0081,    -- Left
													at0082,    -- Right
													at0084,    -- Bilateral
													at0086]    -- Unknown
												}
											}
										}
									}
									ELEMENT[at0085] occurrences matches {0..1} matches {    -- Other associated orthopaedic condition description
										value matches {
											DV_TEXT matches {*}
										}
									}
								}
							}
						}
					}
					ELEMENT[at0011] occurrences matches {0..1} matches {    -- Comment
						value matches {
							DV_TEXT matches {*}
						}
					}
				}
			}
		}
		protocol matches {
			ITEM_TREE[at0001] matches {    -- Item tree
				items cardinality matches {0..*; unordered} matches {
					allow_archetype CLUSTER[at0002] occurrences matches {0..*} matches {    -- Extension
						include
							archetype_id/value matches {/.*/}
					}
				}
			}
		}
	}

ontology
	term_definitions = <
		["en"] = <
			items = <
				["at0000"] = <
					text = <"Orthopaedic clinical follow-up">
					description = <"Structured assessment of orthopaedic clinical follow-up information, including known conditions, complications and associated orthopaedic conditions.">
				>
				["at0001"] = <
					text = <"Item tree">
					description = <"@ internal @">
				>
				["at0002"] = <
					text = <"Extension">
					description = <"">
				>
				["at0003"] = <
					text = <"Item tree">
					description = <"@ internal @">
				>
				["at0004"] = <
					text = <"Other known conditions">
					description = <"Other known pathologies, comorbidities or body system-related conditions recorded at clinical follow-up.">
					comment = <"If status is Present, at least one Other known condition should be recorded.

If status is None known, no Other known condition should be recorded.

If Other is selected, Other known condition description should be recorded.">
				>
				["at0005"] = <
					text = <"Systemic complications">
					description = <"Systemic complications occurring since implantation of this prosthesis.">
					comment = <"If status is Present, at least one systemic complication should be recorded.

If status is None known, no systemic complication should be recorded.

Record each selected complication as a separate Systemic complication instance.

If Other is selected, Other systemic complication description should be recorded.

Record the complication date when available.">
				>
				["at0006"] = <
					text = <"Local complications">
					description = <"Local complications occurring since implantation of this prosthesis.">
					comment = <"If status is Present, at least one local complication should be recorded.

If status is None known, no local complication should be recorded.

Record each selected complication as a separate Local complication instance.

If Other is selected, Other local complication description should be recorded.

Record the complication date or year when available.">
				>
				["at0007"] = <
					text = <"Other associated orthopaedic conditions">
					description = <"Other associated orthopaedic pathologies or conditions relevant to this clinical follow-up.">
					comment = <"If status is Present, at least one associated orthopaedic condition should be recorded.

If status is None known, no associated orthopaedic condition should be recorded.

Record each selected condition as a separate Other associated orthopaedic condition instance.

Record laterality, date or year, and description when applicable.">
				>
				["at0008"] = <
					text = <"Other known condition status">
					description = <"Status indicating whether other known conditions are recorded at this follow-up.">
					comment = <"Use when the presence of other known conditions is unknown or was not assessed.">
				>
				["at0009"] = <
					text = <"Other known condition">
					description = <"Category or specific type of other known condition recorded at clinical follow-up.">
					comment = <"Repeatable element for multiselect use. Record each selected option as a separate instance. Do not record a value when the status is None known.">
				>
				["at0010"] = <
					text = <"Other known condition description">
					description = <"Free-text description of another known condition not represented by the coded options.">
					comment = <"Use when Other is selected, or to provide additional clarification about a selected condition.">
