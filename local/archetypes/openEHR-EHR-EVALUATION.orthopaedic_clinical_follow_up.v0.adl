description
	original_author = <
		["date"] = <"2026-05-16">
		["name"] = <"Jean-Pierre Messerli">
		["organisation"] = <"JPM Consulting GmbH">
		["email"] = <"jean-pierre.messerli@jpm-consulting.ch">
	>
	lifecycle_state = <"unmanaged">
	details = <
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"To record structured information from an orthopaedic clinical follow-up after prosthesis implantation, including the presence or absence of other known conditions, systemic and local complications, other associated orthopaedic conditions, relevant dates or years, laterality where applicable, and additional comments.">
			use = <"Use to document orthopaedic clinical follow-up information in patients with a joint prosthesis, for example after hip or knee arthroplasty.
Use to record whether other known conditions, systemic complications, local complications, or other associated orthopaedic conditions are present, absent, unknown or not assessed.
Use the repeatable nested clusters to record each selected condition or complication as a separate instance, including date or year, laterality and free-text description where applicable.
This archetype may be used in templates for prosthesis follow-up forms, orthopaedic registries, quality documentation, clinical audit and structured follow-up documentation.">
			misuse = <"Not to be used to record the primary operative procedure, implant details, prosthesis components or surgical technique.
Not to be used as a general problem list, diagnosis list or longitudinal comorbidity register. Use appropriate problem/diagnosis archetypes for detailed clinical diagnoses and their lifecycle.
Not to be used to record detailed adverse event management, treatment, medication, procedures or outcome measures unless represented in appropriate additional archetypes.
Not to be used for patient-reported outcome measures, pain scores, functional scores or questionnaire item responses. Use appropriate OBSERVATION archetypes for scores, scales and PROMs.
Not to be used as a replacement for detailed infection, thromboembolic event, neurological event or wound assessment archetypes when detailed clinical documentation is required.">
		>
		["fr"] = <
			language = <[ISO_639-1::fr]>
			purpose = <"Enregistrer des informations structurées issues d’un suivi clinique orthopédique après implantation d’une prothèse, incluant la présence ou l’absence d’autres conditions connues, de complications systémiques et locales, d’autres conditions orthopédiques associées, des dates ou années pertinentes, la latéralité le cas échéant, ainsi que des commentaires complémentaires.">
			copyright = <"© openEHR Foundation">
			use = <"Utiliser pour documenter les informations de suivi clinique orthopédique chez les patients porteurs d’une prothèse articulaire, par exemple après une arthroplastie de la hanche ou du genou. Utiliser pour enregistrer si d’autres conditions connues, des complications systémiques, des complications locales ou d’autres conditions orthopédiques associées sont présentes, absentes, inconnues ou non évaluées. Utiliser les clusters imbriqués répétables pour enregistrer chaque condition ou complication sélectionnée comme une instance distincte, incluant la date ou l’année, la latéralité et une description en texte libre le cas échéant. Cet archétype peut être utilisé dans des templates pour formulaires de suivi de prothèse, registres orthopédiques, documentation qualité, audit clinique et documentation structurée de suivi.">
			misuse = <"Ne pas utiliser pour enregistrer l’intervention opératoire principale, les détails de l’implant, les composants de la prothèse ou la technique chirurgicale. Ne pas utiliser comme liste générale de problèmes, liste de diagnostics ou registre longitudinal des comorbidités. Utiliser des archétypes appropriés de problèmes/diagnostics pour documenter les diagnostics cliniques détaillés et leur cycle de vie. Ne pas utiliser pour enregistrer la prise en charge détaillée d’événements indésirables, les traitements, médicaments, procédures ou mesures de résultats, sauf si ces informations sont représentées dans des archétypes additionnels appropriés. Ne pas utiliser pour les mesures de résultats rapportées par les patients, les scores de douleur, les scores fonctionnels ou les réponses à des questionnaires. Utiliser des archétypes OBSERVATION appropriés pour les scores, échelles et PROMs. Ne pas utiliser comme remplacement d’archétypes détaillés d’infection, d’événement thromboembolique, d’événement neurologique ou d’évaluation de plaie lorsqu’une documentation clinique détaillée est requise.">
		>
	>
