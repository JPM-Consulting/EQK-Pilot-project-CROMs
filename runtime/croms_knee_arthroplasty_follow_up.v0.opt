                <items id="description"></items>
            </items>
            <items code="at0017">
                <items id="text">Détails des implants antérieurs</items>
                <items id="description">Informations supplémentaires sur les implants antérieurs, telles que le type, la localisation anatomique, la latéralité, la date ou le statut de retrait.</items>
            </items>
            <items code="at0018">
                <items id="text">Alignement coronal de l’arthroplastie du genou</items>
                <items id="description">Mesures de l’alignement de l’implant en projection AP.</items>
                <items id="comment">Référence image [img].</items>
            </items>
            <items code="at0019">
                <items id="text">Angle fémoral alpha</items>
                <items id="description">Angle alpha d’alignement du composant fémoral tel que défini dans le formulaire source de cotation radiographique.</items>
            </items>
            <items code="at0020">
                <items id="text">Angle tibial bêta</items>
                <items id="description">Angle bêta d’alignement du composant tibial tel que défini dans le formulaire source de cotation radiographique.</items>
            </items>
            <items code="at0021">
                <items id="text">Angle de valgus total</items>
                <items id="description">Angle global d’alignement en valgus dérivé des mesures d’alignement des composants fémoral et tibial.</items>
            </items>
