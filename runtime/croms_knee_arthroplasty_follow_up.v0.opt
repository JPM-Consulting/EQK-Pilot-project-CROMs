                <items id="description"></items>
            </items>
            <items code="at0100">
                <items id="text">Condition physique du patient</items>
                <items id="description">Évaluation rapportée par un clinicien de la condition physique globale du patient en relation avec l’âge.</items>
            </items>
            <items code="at0101">
                <items id="text">Score genou total</items>
                <items id="description">Score genou total calculé à partir des items du score genou selon l’algorithme de cotation configuré.</items>
                <items id="comment">L’algorithme de cotation n’est pas défini par cet archétype. Les implémentations doivent définir la logique de calcul, l’étendue du score et son interprétation dans le template, la logique applicative ou le guide d’implémentation.</items>
            </items>
            <items code="at0102">
                <items id="text">Score fonction total</items>
                <items id="description">Score fonction total calculé à partir des items du score fonction selon l’algorithme de cotation configuré.</items>
                <items id="comment">L’algorithme de cotation n’est pas défini par cet archétype. Les implémentations doivent définir la logique de calcul, l’étendue du score et son interprétation dans le template, la logique applicative ou le guide d’implémentation.</items>
            </items>
            <items code="deg">
                <items id="text">°</items>
                <items id="description">degree</items>
            </items>
        </term_definitions>
    </component_ontologies>
    <component_ontologies archetype_id="openEHR-EHR-EVALUATION.orthopaedic_clinical_follow_up.v0">
        <term_definitions language="fr">
            <items code="at0000">
                <items id="text">Suivi clinique orthopédique</items>
                <items id="description">Évaluation structurée des informations de suivi clinique orthopédique, incluant les pathologies connues, les complications et les pathologies orthopédiques associées.</items>
            </items>
            <items code="at0001">
                <items id="text">Arborescence des éléments</items>
                <items id="description">@ internal @</items>
            </items>
            <items code="at0002">
                <items id="text">Extension</items>
                <items id="description"></items>
            </items>
            <items code="at0003">
                <items id="text">Arborescence des éléments</items>
                <items id="description">@ internal @</items>
            </items>
            <items code="at0004">
                <items id="text">Autres pathologies connues</items>
                <items id="description">Autres pathologies connues, comorbidités ou affections liées à un système corporel, enregistrées lors du suivi clinique.</items>
                <items id="comment">Si le statut est « Présente », au moins une autre pathologie connue doit être enregistrée.

Si le statut est « Aucune », aucune autre pathologie connue ne doit être enregistrée.

Si « Autre » est sélectionné, une description de l’autre pathologie connue doit être enregistrée.</items>
            </items>
            <items code="at0005">
                <items id="text">Complications systémiques</items>
                <items id="description">Complications systémiques survenues depuis la mise en place de cette prothèse.</items>
                <items id="comment">Si le statut est « Présente », au moins une complication systémique doit être enregistrée.

Si le statut est « Aucune », aucune complication systémique ne doit être enregistrée.

Enregistrer chaque complication sélectionnée comme une instance distincte de complication systémique.

Si « Autre » est sélectionné, une description de l’autre complication systémique doit être enregistrée.

Enregistrer la date de la complication lorsqu’elle est disponible.</items>
            </items>
            <items code="at0006">
                <items id="text">Complications locales</items>
                <items id="description">Complications locales survenues depuis la mise en place de cette prothèse.</items>
                <items id="comment">Si le statut est « Présente », au moins une complication locale doit être enregistrée.

Si le statut est « Aucune », aucune complication locale ne doit être enregistrée.

Enregistrer chaque complication sélectionnée comme une instance distincte de complication locale.

Si « Autre » est sélectionné, une description de l’autre complication locale doit être enregistrée.

Enregistrer la date ou l’année de la complication lorsqu’elle est disponible.</items>
            </items>
            <items code="at0007">
                <items id="text">Autres pathologies orthopédiques associées</items>
                <items id="description">Autres pathologies orthopédiques associées pertinentes pour ce suivi clinique.</items>
                <items id="comment">Si le statut est « Présente », au moins une pathologie orthopédique associée doit être enregistrée.

Si le statut est « Aucune », aucune pathologie orthopédique associée ne doit être enregistrée.

Enregistrer chaque pathologie sélectionnée comme une instance distincte d’autre pathologie orthopédique associée.

Enregistrer la latéralité, la date ou l’année, ainsi qu’une description le cas échéant.</items>
            </items>
            <items code="at0008">
                <items id="text">Statut des autres pathologies connues</items>
                <items id="description">Statut indiquant si d’autres pathologies connues sont enregistrées lors de ce suivi.</items>
                <items id="comment">Utiliser lorsque la présence d’autres pathologies connues est inconnue ou n’a pas été évaluée.</items>
            </items>
            <items code="at0009">
                <items id="text">Autre pathologie connue</items>
                <items id="description">Catégorie ou type spécifique d’autre pathologie connue enregistrée lors du suivi clinique.</items>
                <items id="comment">Élément répétable pour une utilisation en sélection multiple. Enregistrer chaque option sélectionnée comme une instance distincte. Ne pas enregistrer de valeur lorsque le statut est « Aucune ».</items>
            </items>
            <items code="at0010">
                <items id="text">Description d’une autre pathologie connue</items>
                <items id="description">Description en texte libre d’une autre pathologie connue non représentée par les options codées.</items>
                <items id="comment">Utiliser lorsque « Autre » est sélectionné, ou pour fournir des précisions supplémentaires sur une pathologie sélectionnée.</items>
            </items>
            <items code="at0011">
                <items id="text">Commentaire</items>
                <items id="description">Commentaire complémentaire en texte libre concernant le suivi clinique orthopédique.</items>
            </items>
            <items code="at0015">
                <items id="text">Aucune</items>
                <items id="description">Aucune autre pathologie connue n’est enregistrée lors de ce suivi.</items>
            </items>
            <items code="at0016">
                <items id="text">Présente</items>
                <items id="description">Une ou plusieurs autres pathologies connues sont enregistrées.</items>
            </items>
            <items code="at0017">
                <items id="text">Inconnue ou non évaluée</items>
                <items id="description">La présence d’autres pathologies est inconnue ou n’a pas été évaluée.</items>
            </items>
            <items code="at0018">
                <items id="text">Système nerveux</items>
                <items id="description">Pathologie connue liée au système nerveux.</items>
            </items>
            <items code="at0019">
                <items id="text">Système gastro-intestinal</items>
                <items id="description">Pathologie connue liée au système gastro-intestinal.</items>
            </items>
            <items code="at0020">
                <items id="text">Ostéoporose</items>
                <items id="description">Ostéoporose connue.</items>
            </items>
            <items code="at0021">
                <items id="text">Voies respiratoires</items>
                <items id="description">Pathologie connue liée aux voies respiratoires.</items>
            </items>
            <items code="at0022">
                <items id="text">Système uro-génital</items>
                <items id="description">Pathologie connue liée au système uro-génital.</items>
            </items>
            <items code="at0023">
                <items id="text">Système endocrinien</items>
                <items id="description">Pathologie connue liée au système endocrinien.</items>
            </items>
            <items code="at0024">
                <items id="text">Système cardio-vasculaire</items>
                <items id="description">Pathologie connue liée au système cardio-vasculaire.</items>
            </items>
            <items code="at0025">
                <items id="text">Diabète</items>
                <items id="description">Diabète sucré connu.</items>
            </items>
            <items code="at0026">
                <items id="text">Autre</items>
                <items id="description">Autre pathologie connue non représentée par les options listées.</items>
            </items>
            <items code="at0027">
                <items id="text">Statut des complications systémiques</items>
                <items id="description">Statut indiquant si des complications systémiques sont enregistrées depuis la mise en place de la prothèse.</items>
                <items id="comment">Utiliser « Présente » lorsqu’une ou plusieurs complications systémiques sont enregistrées. Utiliser « Aucune » uniquement lorsqu’aucune complication systémique n’est enregistrée. Utiliser « Inconnue ou non évaluée » lorsque cette information n’est pas disponible ou n’a pas été évaluée.</items>
            </items>
            <items code="at0028">
                <items id="text">Aucune</items>
                <items id="description">Aucune complication systémique n’est enregistrée depuis la mise en place de la prothèse.</items>
            </items>
            <items code="at0029">
                <items id="text">Présente</items>
                <items id="description">Une ou plusieurs complications systémiques sont enregistrées depuis la mise en place de la prothèse.</items>
            </items>
            <items code="at0030">
                <items id="text">Inconnue ou non évaluée</items>
                <items id="description">Il est inconnu ou non évalué si des complications systémiques sont survenues.</items>
            </items>
            <items code="at0032">
                <items id="text">Complication systémique</items>
                <items id="description">Complication systémique unique enregistrée depuis la mise en place de cette prothèse.</items>
                <items id="comment">Cluster répétable pour une utilisation en sélection multiple. Enregistrer chaque complication sélectionnée comme une instance distincte, avec sa date lorsqu’elle est disponible.</items>
            </items>
            <items code="at0034">
                <items id="text">Type de complication systémique</items>
                <items id="description">Catégorie ou type spécifique de complication systémique enregistrée depuis la mise en place de la prothèse.</items>
                <items id="comment">Utiliser une valeur codée pour chaque instance de complication systémique. Utiliser « Autre » lorsque la complication n’est pas représentée par les options listées.</items>
            </items>
            <items code="at0035">
                <items id="text">Embolie pulmonaire</items>
                <items id="description">Embolie pulmonaire survenue depuis la mise en place de la prothèse.</items>
            </items>
            <items code="at0036">
                <items id="text">Thrombophlébite</items>
                <items id="description">Thrombophlébite survenue depuis la mise en place de la prothèse.</items>
            </items>
            <items code="at0037">
                <items id="text">Système nerveux central</items>
                <items id="description">Complication systémique liée au système nerveux central.</items>
            </items>
            <items code="at0038">
                <items id="text">Voies respiratoires</items>
                <items id="description">Complication systémique liée aux voies respiratoires.</items>
            </items>
            <items code="at0039">
                <items id="text">Système cardio-vasculaire</items>
                <items id="description">Complication systémique liée au système cardio-vasculaire.</items>
            </items>
            <items code="at0040">
                <items id="text">Urologie</items>
                <items id="description">Complication systémique liée au système urinaire ou urologique.</items>
            </items>
            <items code="at0041">
                <items id="text">Système gastro-intestinal</items>
                <items id="description">Complication systémique liée au système gastro-intestinal.</items>
            </items>
            <items code="at0042">
                <items id="text">Autre</items>
                <items id="description">Autre complication systémique non représentée par les options listées.</items>
            </items>
            <items code="at0044">
                <items id="text">Date de la complication</items>
                <items id="description">Date à laquelle la complication systémique est survenue ou a été identifiée.</items>
                <items id="comment">Enregistrer la date à côté de la complication systémique lorsqu’elle est disponible.</items>
            </items>
            <items code="at0045">
                <items id="text">Description d’une autre complication systémique</items>
                <items id="description">Description en texte libre d’une complication systémique non représentée par les options codées.</items>
                <items id="comment">Utiliser lorsque « Autre » est sélectionné, ou pour fournir des précisions supplémentaires sur une complication systémique sélectionnée.</items>
            </items>
            <items code="at0046">
                <items id="text">Statut des complications locales</items>
                <items id="description">Statut indiquant si des complications locales sont enregistrées depuis la mise en place de la prothèse.</items>
                <items id="comment">Utiliser « Présente » lorsqu’une ou plusieurs complications locales sont enregistrées. Utiliser « Aucune » uniquement lorsqu’aucune complication locale n’est enregistrée. Utiliser « Inconnue ou non évaluée » lorsque cette information n’est pas disponible ou n’a pas été évaluée.</items>
            </items>
            <items code="at0047">
                <items id="text">Aucune</items>
                <items id="description">Aucune complication locale n’est enregistrée depuis la mise en place de la prothèse.</items>
            </items>
            <items code="at0048">
                <items id="text">Présente</items>
                <items id="description">Une ou plusieurs complications locales sont enregistrées depuis la mise en place de la prothèse.</items>
            </items>
            <items code="at0049">
                <items id="text">Inconnue ou non évaluée</items>
                <items id="description">Il est inconnu ou non évalué si des complications locales sont survenues.</items>
            </items>
            <items code="at0050">
                <items id="text">Complication locale</items>
                <items id="description">Complication locale unique enregistrée depuis la mise en place de cette prothèse.</items>
                <items id="comment">Cluster répétable pour une utilisation en sélection multiple. Enregistrer chaque complication sélectionnée comme une instance distincte, avec sa date ou son année lorsqu’elle est disponible.</items>
            </items>
            <items code="at0051">
                <items id="text">Type de complication locale</items>
                <items id="description">Catégorie ou type spécifique de complication locale enregistrée depuis la mise en place de la prothèse.</items>
                <items id="comment">Utiliser une valeur codée pour chaque instance de complication locale. Utiliser « Autre » lorsque la complication n’est pas représentée par les options listées.</items>
            </items>
            <items code="at0052">
                <items id="text">Luxation</items>
                <items id="description">Luxation locale survenue depuis la mise en place de la prothèse.</items>
            </items>
            <items code="at0053">
                <items id="text">Hématome / sérome</items>
                <items id="description">Hématome ou sérome local survenu depuis la mise en place de la prothèse.</items>
            </items>
            <items code="at0054">
                <items id="text">Drainage persistant</items>
                <items id="description">Drainage persistant de la plaie survenu depuis la mise en place de la prothèse.</items>
            </items>
            <items code="at0055">
                <items id="text">Déhiscence</items>
                <items id="description">Déhiscence de la plaie survenue depuis la mise en place de la prothèse.</items>
            </items>
            <items code="at0056">
                <items id="text">Neurapraxie</items>
                <items id="description">Neuro-praxie locale survenue depuis la mise en place de la prothèse.</items>
            </items>
            <items code="at0057">
                <items id="text">Descellement</items>
                <items id="description">Descellement de la prothèse survenu depuis sa mise en place.</items>
            </items>
            <items code="at0058">
                <items id="text">Sepsis profond</items>
                <items id="description">Sepsis profond ou infection profonde survenu depuis la mise en place de la prothèse.</items>
            </items>
            <items code="at0059">
                <items id="text">Sepsis superficiel</items>
                <items id="description">Sepsis superficiel ou infection superficielle survenu depuis la mise en place de la prothèse.</items>
            </items>
            <items code="at0060">
                <items id="text">Autre</items>
                <items id="description">Autre complication locale non représentée par les options listées.</items>
            </items>
            <items code="at0061">
                <items id="text">Date de la complication</items>
                <items id="description">Date ou année à laquelle la complication locale est survenue ou a été identifiée.</items>
                <items id="comment">Enregistrer la date ou l’année à côté de la complication lorsqu’elle est disponible.</items>
            </items>
            <items code="at0062">
                <items id="text">Description d’une autre complication locale</items>
                <items id="description">Description en texte libre d’une complication locale non représentée par les options codées.</items>
                <items id="comment">Utiliser lorsque « Autre » est sélectionné, ou pour fournir des précisions supplémentaires sur une complication locale sélectionnée.</items>
            </items>
            <items code="at0063">
                <items id="text">Statut des autres pathologies orthopédiques associées</items>
                <items id="description">Statut indiquant si d’autres pathologies orthopédiques associées sont enregistrées lors de ce suivi.</items>
                <items id="comment">Utiliser « Présente » lorsqu’une ou plusieurs pathologies orthopédiques associées sont enregistrées. Utiliser « Aucune » uniquement lorsqu’aucune pathologie orthopédique associée n’est enregistrée. Utiliser « Inconnue ou non évaluée » lorsque cette information n’est pas disponible ou n’a pas été évaluée.</items>
            </items>
            <items code="at0064">
                <items id="text">Aucune</items>
                <items id="description">Aucune autre pathologie orthopédique associée n’est enregistrée lors de ce suivi.</items>
            </items>
            <items code="at0065">
                <items id="text">Présente</items>
                <items id="description">Une ou plusieurs autres pathologies orthopédiques associées sont enregistrées lors de ce suivi.</items>
            </items>
            <items code="at0066">
                <items id="text">Inconnue ou non évaluée</items>
                <items id="description">La présence d’autres pathologies orthopédiques associées est inconnue ou n’a pas été évaluée.</items>
            </items>
            <items code="at0067">
                <items id="text">Autre pathologie orthopédique associée</items>
                <items id="description">Autre pathologie orthopédique associée unique enregistrée lors de ce suivi.</items>
                <items id="comment">Cluster répétable pour une utilisation en sélection multiple. Enregistrer chaque pathologie sélectionnée comme une instance distincte, avec la latéralité, la date ou l’année et une description le cas échéant.</items>
            </items>
            <items code="at0069">
                <items id="text">Type d’autre pathologie orthopédique associée</items>
                <items id="description">Catégorie ou type spécifique d’autre pathologie orthopédique associée enregistrée lors du suivi clinique.</items>
                <items id="comment">Utiliser une valeur codée pour chaque instance de pathologie orthopédique associée. Utiliser « Autre » lorsque la pathologie n’est pas représentée par les options listées.</items>
            </items>
            <items code="at0070">
                <items id="text">Genou controlatéral</items>
                <items id="description">Pathologie associée touchant le genou controlatéral.</items>
            </items>
            <items code="at0071">
                <items id="text">Cheville / pied</items>
                <items id="description">Pathologie associée touchant la cheville ou le pied.</items>
            </items>
            <items code="at0072">
                <items id="text">Poignet / main</items>
                <items id="description">Pathologie associée touchant le poignet ou la main.</items>
            </items>
            <items code="at0073">
                <items id="text">Hanche opposée</items>
                <items id="description">Pathologie associée touchant la hanche opposée.</items>
            </items>
            <items code="at0074">
                <items id="text">Épaule</items>
                <items id="description">Pathologie associée touchant l’épaule.</items>
            </items>
            <items code="at0075">
                <items id="text">Trauma</items>
                <items id="description">Pathologie orthopédique associée liée à un traumatisme.</items>
            </items>
            <items code="at0076">
                <items id="text">Colonne vertébrale</items>
                <items id="description">Pathologie associée touchant la colonne vertébrale.</items>
            </items>
            <items code="at0077">
                <items id="text">Coude</items>
                <items id="description">Pathologie associée touchant le coude.</items>
            </items>
            <items code="at0078">
                <items id="text">Autre</items>
                <items id="description">Autre pathologie orthopédique associée non représentée par les options listées.</items>
            </items>
            <items code="at0079">
                <items id="text">Date de la pathologie</items>
                <items id="description">Date ou année à laquelle la pathologie orthopédique associée est survenue ou a été identifiée.</items>
                <items id="comment">Enregistrer la date ou l’année à côté de la pathologie orthopédique associée lorsqu’elle est disponible.</items>
            </items>
            <items code="at0080">
                <items id="text">Latéralité de la pathologie</items>
                <items id="description">Latéralité de la pathologie orthopédique associée, le cas échéant.</items>
                <items id="comment">À enregistrer pour le genou controlatéral ou la hanche opposée le cas échéant, en utilisant le côté anatomique atteint.</items>
            </items>
            <items code="at0081">
                <items id="text">Gauche</items>
                <items id="description">Côté gauche.</items>
            </items>
            <items code="at0082">
                <items id="text">Droit</items>
                <items id="description">Côté droit.</items>
            </items>
            <items code="at0084">
                <items id="text">Bilatérale</items>
                <items id="description">Côtés gauche et droit.</items>
            </items>
            <items code="at0085">
                <items id="text">Description d’une autre pathologie orthopédique associée</items>
                <items id="description">Description en texte libre de la pathologie orthopédique associée.</items>
                <items id="comment">Utiliser lorsque « Trauma » ou « Autre » est sélectionné, ou pour fournir des précisions supplémentaires sur une pathologie orthopédique associée sélectionnée.</items>
            </items>
            <items code="at0086">
                <items id="text">Inconnue</items>
                <items id="description">La latéralité est inconnue.</items>
            </items>
        </term_definitions>
    </component_ontologies>
    <component_ontologies archetype_id="openEHR-EHR-OBSERVATION.knee_arthroplasty_xray_follow_up.v0">
        <term_definitions language="fr">
            <items code="at0000">
                <items id="text">Suivi radiographique d’arthroplastie du genou</items>
                <items id="description">Évaluation radiographique de suivi après arthroplastie du genou, incluant l’alignement de l’implant, les mesures des lignes radiotransparentes propres à chaque composant, les zones du composant rotulien ainsi que les mesures du centrage et de la morphologie rotuliens.</items>
            </items>
            <items code="at0001">
                <items id="text">Historique</items>
                <items id="description">@ internal @</items>
            </items>
            <items code="at0002">
                <items id="text">Tout événement</items>
                <items id="description">@ internal @</items>
            </items>
            <items code="at0003">
                <items id="text">Arborescence</items>
                <items id="description">@ internal @</items>
            </items>
            <items code="at0004">
                <items id="text">Date de radiographie</items>
                <items id="description">Date à laquelle l’examen radiographique a été réalisé, si elle est enregistrée séparément de l’heure de l’événement d’observation.</items>
            </items>
            <items code="at0005">
                <items id="text">Côté du genou</items>
                <items id="description"></items>
            </items>
            <items code="at0006">
                <items id="text">Gauche</items>
                <items id="description">Genou gauche.</items>
            </items>
            <items code="at0007">
                <items id="text">Droit</items>
                <items id="description">Genou droit.</items>
            </items>
            <items code="at0008">
