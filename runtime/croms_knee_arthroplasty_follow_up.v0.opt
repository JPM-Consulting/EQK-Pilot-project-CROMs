                <items id="description"></items>
            </items>
            <items code="at0090">
                <items id="text">Moyens auxiliaires</items>
                <items id="description">Moyens auxiliaires de marche utilisés par le patient pour la mobilité.</items>
            </items>
            <items code="at0091">
                <items id="text">Aucun</items>
                <items id="description"></items>
            </items>
            <items code="at0092">
                <items id="text">1 canne basse</items>
                <items id="description"></items>
            </items>
            <items code="at0093">
