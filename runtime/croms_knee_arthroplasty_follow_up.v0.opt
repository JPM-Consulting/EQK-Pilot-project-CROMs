                <archetype_id>
                    <value>openEHR-EHR-OBSERVATION.knee_arthroplasty_xray_follow_up.v0</value>
                </archetype_id>
                <term_definitions code="at0000">
                    <items id="text">Knee arthroplasty X-ray follow-up</items>
                    <items id="description">Radiographic follow-up assessment after knee arthroplasty, including implant alignment, component-specific radiolucent line measurements, patellar component zones, and patellar tracking and morphology measurements.</items>
                </term_definitions>
                <term_definitions code="at0001">
                    <items id="text">History</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0002">
                    <items id="text">Point in time</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0003">
                    <items id="text">Tree</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0004">
                    <items id="text">X-ray date</items>
                    <items id="description">Date on which the X-ray examination was performed, if recorded separately from the observation event time.</items>
                </term_definitions>
                <term_definitions code="at0005">
                    <items id="text">Knee side</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0006">
                    <items id="text">Left</items>
                    <items id="description">Left knee.</items>
                </term_definitions>
                <term_definitions code="at0007">
                    <items id="text">Right</items>
                    <items id="description">Right knee.</items>
                </term_definitions>
                <term_definitions code="at0008">
                    <items id="text">Patient position during imaging</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0009">
                    <items id="text">Recumbent</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0010">
                    <items id="text">Standing</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0011">
                    <items id="text">HKA angle</items>
                    <items id="description">Hip-knee-ankle angle measured on a weight-bearing full-length lower limb radiograph.</items>
                </term_definitions>
                <term_definitions code="at0012">
                    <items id="text">Prior implant status</items>
                    <items id="description">Presence or absence of prior implants relevant to the knee arthroplasty radiographic follow-up.</items>
                </term_definitions>
                <term_definitions code="at0013">
                    <items id="text">Present</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0014">
                    <items id="text">Absent</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0015">
                    <items id="text">Unknown</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0016">
                    <items id="text">Not assessed</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0017">
                    <items id="text">Prior implant details</items>
                    <items id="description">Additional details about prior implants, such as type, anatomical location, laterality, date or removal status.</items>
                </term_definitions>
                <term_definitions code="at0018">
                    <items id="text">Coronal knee arthroplasty alignment</items>
                    <items id="description">AP implant alignment measurements.</items>
                    <items id="comment">Image-Reference [img].</items>
                </term_definitions>
                <term_definitions code="at0019">
                    <items id="text">Femoral angle alpha</items>
                    <items id="description">Femoral component alignment angle alpha as defined in the source radiographic scoring form.</items>
                </term_definitions>
                <term_definitions code="at0020">
                    <items id="text">Tibial angle beta</items>
                    <items id="description">Tibial component alignment angle beta as defined in the source radiographic scoring form.</items>
                </term_definitions>
                <term_definitions code="at0021">
                    <items id="text">Total valgus angle</items>
                    <items id="description">Overall valgus alignment angle derived from the femoral and tibial component alignment measurements.</items>
                </term_definitions>
                <term_definitions code="at0022">
                    <items id="text">AP film reference</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0023">
                    <items id="text">18-inch film</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0024">
                    <items id="text">3-foot film</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0025">
                    <items id="text">Sagittal knee arthroplasty alignment</items>
                    <items id="description">Lateral implant alignment measurements.</items>
                    <items id="comment">Image-Reference [img].</items>
                </term_definitions>
                <term_definitions code="at0026">
                    <items id="text">Femoral flexion angle</items>
                    <items id="description"></items>
