        <term_definitions code="at0000">
            <items id="text">CROMS knee arthroplasty follow up</items>
            <items id="description">Document to communicate information to others, commonly in response to a request from another party.</items>
        </term_definitions>
        <term_definitions code="at0001">
            <items id="text">Tree</items>
            <items id="description">@ internal @</items>
        </term_definitions>
        <term_definitions code="at0002">
            <items id="text">Report ID</items>
            <items id="description">Identification information about the report.</items>
        </term_definitions>
        <term_definitions code="at0005">
            <items id="text">Status</items>
            <items id="description">The status of the entire report. Note: This is not the status of any of the report components.</items>
        </term_definitions>
        <term_definitions code="at0006">
            <items id="text">Extension</items>
            <items id="description">Additional information required to capture local context or to align with other reference models/formalisms.</items>
            <items id="comment">For example: local information requirements or additional metadata to align with FHIR or CIMI equivalents.</items>
        </term_definitions>
    </definition>
    <ontology archetype_id="openEHR-EHR-COMPOSITION.report.v1">
        <term_definitions language="fr">
            <items code="at0000">
                <items id="text">CROMS suivi genou prothétique</items>
                <items id="description">Document destiné à communiquer des informations à des tiers, généralement en réponse à une demande d’une autre partie.</items>
            </items>
            <items code="at0001">
                <items id="text">Arborescence</items>
                <items id="description">@ internal @</items>
            </items>
            <items code="at0002">
                <items id="text">Identifiant du rapport</items>
                <items id="description">Informations d’identification du rapport.</items>
            </items>
            <items code="at0005">
                <items id="text">Statut</items>
                <items id="description">Statut du rapport dans son ensemble. Remarque : il ne s’agit pas du statut des différents composants du rapport.</items>
            </items>
            <items code="at0006">
                <items id="text">Extension</items>
                <items id="description">Informations supplémentaires nécessaires pour saisir le contexte local ou assurer l’alignement avec d’autres modèles ou formalismes de référence.</items>
                <items id="comment">Par exemple : exigences d’information locales ou métadonnées supplémentaires pour l’alignement avec des équivalents FHIR ou CIMI.</items>
            </items>
        </term_definitions>
    </ontology>
    <component_ontologies archetype_id="openEHR-EHR-EVALUATION.orthopaedic_knee_clinical_follow_up.v0">
        <term_definitions language="fr">
            <items code="at0000">
                <items id="text">Suivi clinique orthopédique du genou</items>
                <items id="description">Évaluation structurée, rapportée par un clinicien, pour le suivi orthopédique du genou, incluant le contexte de l’arthroplastie du genou, la douleur, l’amplitude de mouvement, la stabilité, le flexum passif, le déficit d’extension active, l’alignement clinique, la capacité fonctionnelle et la condition physique du patient en fonction de l’âge.</items>
            </items>
            <items code="at0001">
                <items id="text">Item tree</items>
                <items id="description">@ internal @</items>
            </items>
            <items code="at0003">
                <items id="text">Item tree</items>
                <items id="description">@ internal @</items>
            </items>
            <items code="at0004">
                <items id="text">Nom du clinicien qui consulte</items>
                <items id="description">Nom du clinicien responsable de l’évaluation clinique de suivi ou qui la réalise.</items>
            </items>
            <items code="at0005">
                <items id="text">Contexte de l’arthroplastie du genou</items>
                <items id="description">Informations contextuelles relatives à l’arthroplastie du genou ou à la prothèse du genou, pertinentes pour cette évaluation clinique de suivi.</items>
            </items>
            <items code="at0006">
                <items id="text">Score genou</items>
                <items id="description">Évaluation rapportée par un clinicien de la douleur, de la mobilité, de la stabilité, du flexum passif, du déficit d’extension active et de l’alignement clinique du genou opéré ou évalué.</items>
            </items>
            <items code="at0007">
                <items id="text">Score fonction</items>
                <items id="description">Évaluation rapportée par un clinicien de la capacité fonctionnelle liée à la marche, à l’utilisation des escaliers, aux moyens auxiliaires et au niveau d’activité.</items>
            </items>
            <items code="at0009">
                <items id="text">Contrôle</items>
                <items id="description">Moment de l’évaluation de suivi par rapport à l’intervention, à l’évaluation de référence ou au calendrier de suivi prévu.</items>
            </items>
            <items code="at0010">
                <items id="text">Préopératoire</items>
                <items id="description"></items>
            </items>
            <items code="at0011">
                <items id="text">6 semaines</items>
                <items id="description"></items>
            </items>
            <items code="at0012">
