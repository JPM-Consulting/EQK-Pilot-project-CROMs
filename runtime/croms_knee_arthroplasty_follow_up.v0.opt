                <archetype_id>
                    <value>openEHR-EHR-EVALUATION.orthopaedic_knee_clinical_follow_up.v0</value>
                </archetype_id>
                <term_definitions code="at0000">
                    <items id="text">Knee clinical follow-up</items>
                    <items id="description">A structured clinician-reported assessment for orthopaedic knee follow-up, including knee arthroplasty context, pain, range of motion, stability, flexion contracture, extension lag, clinical alignment, functional ability and the patient's physical condition in relation to age.</items>
                </term_definitions>
                <term_definitions code="at0001">
                    <items id="text">Item tree</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0003">
                    <items id="text">Item tree</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0004">
                    <items id="text">Consulting clinician name</items>
                    <items id="description">Name of the clinician responsible for, or performing, the clinical follow-up assessment.</items>
                </term_definitions>
                <term_definitions code="at0005">
                    <items id="text">Knee arthroplasty context</items>
                    <items id="description">Contextual information about the knee arthroplasty or knee prosthesis relevant to this clinical follow-up assessment.</items>
                </term_definitions>
                <term_definitions code="at0006">
                    <items id="text">Knee score</items>
                    <items id="description">Clinician-reported assessment of pain, mobility, stability, flexion contracture, extension lag and clinical alignment of the operated or assessed knee.</items>
                </term_definitions>
                <term_definitions code="at0007">
                    <items id="text">Function score</items>
                    <items id="description">Clinician-reported assessment of functional ability related to walking, stair use, assistive device use and activity level.</items>
                </term_definitions>
                <term_definitions code="at0009">
                    <items id="text">Follow-up timing</items>
                    <items id="description">Timing of the follow-up assessment in relation to surgery, baseline assessment or the planned follow-up schedule.</items>
                </term_definitions>
                <term_definitions code="at0010">
                    <items id="text">Preoperative</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0011">
                    <items id="text">6 weeks</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0012">
                    <items id="text">3 months</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0013">
                    <items id="text">6 months</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0014">
                    <items id="text">1 year</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0015">
                    <items id="text">2 years</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0016">
                    <items id="text">Other number of years</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0017">
                    <items id="text">Other follow-up interval in years</items>
                    <items id="description">Number of years after surgery or baseline assessment for follow-up timing, used when "Other number of years" is selected.</items>
                </term_definitions>
                <term_definitions code="at0018">
                    <items id="text">Type of prosthesis</items>
                    <items id="description">Type or product family of the knee prosthesis relevant to this follow-up assessment.</items>
                </term_definitions>
                <term_definitions code="at0019">
                    <items id="text">First</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0020">
                    <items id="text">First Evolution</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0021">
                    <items id="text">First Sensitive</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0022">
                    <items id="text">Origin</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0023">
                    <items id="text">NexGen LCCK</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0024">
                    <items id="text">NexGen standard</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0025">
                    <items id="text">Triathlon</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0026">
                    <items id="text">PUC</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0027">
                    <items id="text">PFJ</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0028">
                    <items id="text">Other</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0029">
                    <items id="text">Other prosthesis type</items>
                    <items id="description">Free-text description of the prosthesis type when the coded value "Other" is selected.</items>
                </term_definitions>
                <term_definitions code="at0030">
                    <items id="text">Side operated or to be operated</items>
                    <items id="description">Laterality of the knee that has been operated on or is planned for operation.</items>
                </term_definitions>
                <term_definitions code="at0031">
                    <items id="text">Right</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0032">
                    <items id="text">Left</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0033">
                    <items id="text">Pain while walking</items>
                    <items id="description">Clinician-reported assessment of knee pain experienced while walking.</items>
                </term_definitions>
                <term_definitions code="at0034">
                    <items id="text">None</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0035">
                    <items id="text">Mild or occasional</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0036">
                    <items id="text">Moderate</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0037">
                    <items id="text">Severe</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0038">
                    <items id="text">Pain on stairs</items>
                    <items id="description">Clinician-reported assessment of knee pain experienced when using stairs.</items>
                </term_definitions>
                <term_definitions code="at0039">
                    <items id="text">None</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0040">
                    <items id="text">Mild or occasional</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0041">
                    <items id="text">Moderate</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0042">
                    <items id="text">Severe</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0043">
                    <items id="text">Pain at rest</items>
                    <items id="description">Clinician-reported assessment of knee pain experienced at rest.</items>
                </term_definitions>
                <term_definitions code="at0044">
                    <items id="text">None</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0045">
                    <items id="text">Mild</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0046">
                    <items id="text">Moderate</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0047">
                    <items id="text">Severe</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0048">
                    <items id="text">Flexion-neutral-extension range of motion</items>
                    <items id="description">Range of motion of the knee documented using the neutral-zero method.</items>
                </term_definitions>
                <term_definitions code="at0049">
                    <items id="text">Maximum flexion angle</items>
                    <items id="description">Maximum flexion angle of the assessed knee, expressed in degrees.</items>
                </term_definitions>
                <term_definitions code="at0050">
                    <items id="text">Neutral position angle</items>
                    <items id="description">Neutral-zero reference position of the assessed knee, usually documented as 0 degrees.</items>
                </term_definitions>
                <term_definitions code="at0051">
                    <items id="text">Maximum extension angle</items>
                    <items id="description">Maximum extension angle or extension deficit of the assessed knee, expressed in degrees.</items>
                </term_definitions>
                <term_definitions code="at0052">
                    <items id="text">Medial-lateral stability in valgus/varus</items>
                    <items id="description">Clinician-assessed medial-lateral stability of the knee during valgus and varus stress testing.</items>
                </term_definitions>
                <term_definitions code="at0053">
                    <items id="text">5 degrees or less</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0054">
                    <items id="text">6 to 10 degrees</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0055">
                    <items id="text">More than 10 degrees</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0056">
                    <items id="text">Anterior-posterior stability</items>
                    <items id="description">Clinician-assessed anterior-posterior stability of the knee, expressed as a categorical range in millimetres.</items>
                </term_definitions>
                <term_definitions code="at0057">
                    <items id="text">0 to 5 mm</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0058">
                    <items id="text">6 to 10 mm</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0059">
                    <items id="text">More than 10 mm</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0060">
                    <items id="text">Passive flexion contracture</items>
                    <items id="description">Clinician-assessed passive flexion contracture of the knee, expressed as a categorical angular range.</items>
                </term_definitions>
                <term_definitions code="at0061">
                    <items id="text">5 degrees or less</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0062">
                    <items id="text">6 to 10 degrees</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0063">
                    <items id="text">11 to 20 degrees</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0064">
                    <items id="text">More than 20 degrees</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0065">
                    <items id="text">Active extension lag</items>
                    <items id="description">Clinician-assessed difference between passive and active knee extension, expressed as a categorical angular range.</items>
                </term_definitions>
                <term_definitions code="at0066">
                    <items id="text">None</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0067">
                    <items id="text">Less than 4 degrees</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0068">
                    <items id="text">5 to 10 degrees</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0069">
                    <items id="text">More than 11 degrees</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0070">
                    <items id="text">Clinical alignment</items>
                    <items id="description">Clinician-reported coronal plane alignment of the assessed knee, documented as valgus or varus angle.</items>
                </term_definitions>
                <term_definitions code="at0071">
                    <items id="text">Valgus angle</items>
                    <items id="description">Clinical valgus alignment angle of the assessed knee, expressed in degrees.</items>
                </term_definitions>
                <term_definitions code="at0072">
                    <items id="text">Varus angle</items>
                    <items id="description">Clinical varus alignment angle of the assessed knee, expressed in degrees.</items>
                </term_definitions>
                <term_definitions code="at0073">
                    <items id="text">Condition depending on age</items>
                    <items id="description">Overall physical condition assessed in relation to the patient's age.</items>
                </term_definitions>
                <term_definitions code="at0074">
                    <items id="text">Excellent</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0075">
                    <items id="text">Good</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0076">
                    <items id="text">Average</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0077">
                    <items id="text">Poor</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0078">
                    <items id="text">Walking ability</items>
                    <items id="description">Clinician-reported assessment of the patient's walking capacity, based on distance or duration.</items>
                </term_definitions>
                <term_definitions code="at0079">
                    <items id="text">Unlimited or more than 1 hour</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0080">
                    <items id="text">More than 1000 m</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0081">
                    <items id="text">500 to 1000 m or more than 30 minutes</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0082">
                    <items id="text">Less than 500 m or 15 minutes or less</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0083">
                    <items id="text">At home only</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0084">
                    <items id="text">Impossible</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0085">
                    <items id="text">Stairs</items>
                    <items id="description">Clinician-reported assessment of the patient's ability to ascend and descend stairs.</items>
                </term_definitions>
                <term_definitions code="at0086">
                    <items id="text">Up and down stairs normally</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0087">
                    <items id="text">Up normally, down with handrail</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0088">
                    <items id="text">Up and down with handrail</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0089">
                    <items id="text">Up with handrail, down impossible</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0090">
                    <items id="text">Assistive devices</items>
                    <items id="description">Assistive walking devices used by the patient for mobility.</items>
                </term_definitions>
                <term_definitions code="at0091">
                    <items id="text">None</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0092">
                    <items id="text">One cane</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0093">
                    <items id="text">Two canes</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0094">
                    <items id="text">Two Canadian crutches or walker</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0095">
                    <items id="text">Activity level</items>
                    <items id="description">Clinician-reported assessment of the patient's general activity and independence level.</items>
                </term_definitions>
                <term_definitions code="at0096">
                    <items id="text">High</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0097">
                    <items id="text">Daily activity</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0098">
                    <items id="text">Independent</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0099">
                    <items id="text">Not independent</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0100">
                    <items id="text">Patient physical condition</items>
                    <items id="description">Clinician-reported assessment of the patient's overall physical condition in relation to age.</items>
                </term_definitions>
                <term_definitions code="at0101">
                    <items id="text">Knee score total</items>
                    <items id="description">Calculated total knee score derived from the knee score items according to the configured scoring algorithm.</items>
                    <items id="comment">The scoring algorithm is not defined by this archetype. Implementations must define the calculation logic, score range and interpretation in the template, application logic or implementation guide.</items>
                </term_definitions>
                <term_definitions code="at0102">
                    <items id="text">Function score total</items>
                    <items id="description">Calculated total function score derived from the function score items according to the configured scoring algorithm.</items>
                    <items id="comment">The scoring algorithm is not defined by this archetype. Implementations must define the calculation logic, score range and interpretation in the template, application logic or implementation guide.</items>
                </term_definitions>
                <term_definitions code="deg">
                    <items id="text">°</items>
                    <items id="description">degree</items>
                </term_definitions>
            </children>
