                <items id="description"></items>
            </items>
            <items code="at0069">
                <items id="text">Plus de 11 degrés</items>
                <items id="description"></items>
            </items>
            <items code="at0070">
                <items id="text">Alignement clinique</items>
                <items id="description">Alignement clinique dans le plan coronal du genou évalué, documenté comme angle en valgus ou en varus.</items>
            </items>
            <items code="at0071">
                <items id="text">Angle de valgus</items>
                <items id="description">Angle d’alignement clinique en valgus du genou évalué, exprimé en degrés.</items>
            </items>
            <items code="at0072">
                <items id="text">Angle de varus</items>
                <items id="description">Angle d’alignement clinique en varus du genou évalué, exprimé en degrés.</items>
            </items>
            <items code="at0073">
                <items id="text">Condition physique du patient selon l’âge</items>
                <items id="description">Condition physique globale évaluée en relation avec l’âge du patient.</items>
            </items>
            <items code="at0074">
                <items id="text">Excellente</items>
                <items id="description"></items>
            </items>
            <items code="at0075">
                <items id="text">Bonne</items>
                <items id="description"></items>
            </items>
            <items code="at0076">
                <items id="text">Moyenne</items>
                <items id="description"></items>
            </items>
            <items code="at0077">
                <items id="text">Faible</items>
                <items id="description"></items>
            </items>
            <items code="at0078">
                <items id="text">Marche</items>
                <items id="description">Évaluation rapportée par un clinicien de la capacité de marche du patient, basée sur la distance ou la durée.</items>
            </items>
            <items code="at0079">
                <items id="text">Illimitée ou plus de 1 h</items>
                <items id="description"></items>
            </items>
            <items code="at0080">
                <items id="text">Plus de 1000 m</items>
                <items id="description"></items>
            </items>
            <items code="at0081">
                <items id="text">500 à 1000 m ou plus de 30 min</items>
                <items id="description"></items>
            </items>
            <items code="at0082">
                <items id="text">Moins de 500 m ou 15 min ou moins</items>
                <items id="description"></items>
            </items>
            <items code="at0083">
                <items id="text">Au domicile</items>
                <items id="description"></items>
            </items>
            <items code="at0084">
                <items id="text">Impossible</items>
                <items id="description"></items>
            </items>
            <items code="at0085">
                <items id="text">Escaliers</items>
                <items id="description">Évaluation rapportée par un clinicien de la capacité du patient à monter et descendre les escaliers.</items>
            </items>
            <items code="at0086">
                <items id="text">Montée et descente sans rampe</items>
                <items id="description"></items>
            </items>
            <items code="at0087">
                <items id="text">Montée sans rampe, descente avec rampe</items>
                <items id="description"></items>
            </items>
            <items code="at0088">
