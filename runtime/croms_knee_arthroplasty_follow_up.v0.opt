                <items id="description"></items>
            </items>
            <items code="at0043">
                <items id="text">Douleur au repos</items>
                <items id="description">Évaluation rapportée par un clinicien de la douleur du genou ressentie au repos.</items>
            </items>
            <items code="at0044">
                <items id="text">Aucune</items>
                <items id="description"></items>
            </items>
            <items code="at0045">
                <items id="text">Légère</items>
                <items id="description"></items>
            </items>
