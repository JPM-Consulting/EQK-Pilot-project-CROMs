                <items id="description"></items>
            </items>
            <items code="at0060">
                <items id="text">Flexum passif</items>
                <items id="description">Flexum passif du genou évalué par le clinicien, exprimé sous forme de catégorie angulaire.</items>
            </items>
            <items code="at0061">
                <items id="text">5 degrés ou moins</items>
                <items id="description"></items>
            </items>
            <items code="at0062">
                <items id="text">6 à 10 degrés</items>
                <items id="description"></items>
            </items>
            <items code="at0063">
                <items id="text">11 à 20 degrés</items>
                <items id="description"></items>
            </items>
            <items code="at0064">
                <items id="text">Plus de 20 degrés</items>
                <items id="description"></items>
            </items>
            <items code="at0065">
                <items id="text">Flexum actif</items>
                <items id="description">Différence entre l’extension passive et l’extension active du genou, évaluée par le clinicien et exprimée sous forme de catégorie angulaire.</items>
            </items>
            <items code="at0066">
                <items id="text">Aucun</items>
                <items id="description"></items>
            </items>
            <items code="at0067">
