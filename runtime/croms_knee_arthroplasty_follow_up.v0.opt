            <items code="at0047">
                <items id="text">Sévère</items>
                <items id="description"></items>
            </items>
            <items code="at0048">
                <items id="text">Mobilité</items>
                <items id="description">Amplitude de mouvement du genou documentée selon la méthode neutre-zéro.</items>
            </items>
            <items code="at0049">
                <items id="text">Angle maximal de flexion</items>
                <items id="description">Angle maximal de flexion du genou évalué, exprimé en degrés.</items>
            </items>
            <items code="at0050">
                <items id="text">Angle en position neutre</items>
                <items id="description">Position de référence neutre-zéro du genou évalué, généralement documentée comme 0 degré.</items>
            </items>
            <items code="at0051">
                <items id="text">Angle maximal d’extension</items>
                <items id="description">Angle maximal d’extension ou déficit d’extension du genou évalué, exprimé en degrés.</items>
            </items>
            <items code="at0052">
                <items id="text">Stabilité en valgus/varus</items>
                <items id="description">Stabilité médio-latérale du genou évaluée par le clinicien lors des tests de stress en valgus et en varus.</items>
            </items>
            <items code="at0053">
                <items id="text">5 degrés ou moins</items>
                <items id="description"></items>
            </items>
            <items code="at0054">
                <items id="text">6 à 10 degrés</items>
                <items id="description"></items>
            </items>
            <items code="at0055">
                <items id="text">Plus de 10 degrés</items>
                <items id="description"></items>
            </items>
            <items code="at0056">
                <items id="text">Stabilité A/P</items>
                <items id="description">Stabilité antéro-postérieure du genou évaluée par le clinicien, exprimée sous forme de catégorie en millimètres.</items>
            </items>
            <items code="at0057">
                <items id="text">0 à 5 mm</items>
                <items id="description"></items>
            </items>
            <items code="at0058">
