                <items id="description"></items>
            </items>
            <items code="at0010">
                <items id="text">Debout</items>
                <items id="description"></items>
            </items>
            <items code="at0011">
                <items id="text">Angle HKA</items>
                <items id="description">Angle hanche-genou-cheville mesuré sur une radiographie du membre inférieur entier en charge.</items>
            </items>
            <items code="at0012">
                <items id="text">Statut des implants antérieurs</items>
                <items id="description">Présence ou absence d’implants antérieurs pertinents pour le suivi radiographique de l’arthroplastie du genou.</items>
            </items>
            <items code="at0013">
                <items id="text">Présent</items>
                <items id="description"></items>
            </items>
            <items code="at0014">
