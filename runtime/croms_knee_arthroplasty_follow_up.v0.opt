                <archetype_id>
                    <value>openEHR-EHR-EVALUATION.orthopaedic_clinical_follow_up.v0</value>
                </archetype_id>
                <term_definitions code="at0000">
                    <items id="text">Orthopaedic clinical background and follow-up</items>
                    <items id="description">Structured assessment of orthopaedic clinical follow-up information, including known conditions, complications and associated orthopaedic conditions.</items>
                </term_definitions>
                <term_definitions code="at0001">
                    <items id="text">Item tree</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0002">
                    <items id="text">Extension</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0003">
                    <items id="text">Item tree</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0004">
                    <items id="text">Other known conditions</items>
                    <items id="description">Other known pathologies, comorbidities or body system-related conditions recorded at clinical follow-up.</items>
                    <items id="comment">If status is Present, at least one Other known condition should be recorded.

If status is None known, no Other known condition should be recorded.

If Other is selected, Other known condition description should be recorded.</items>
                </term_definitions>
                <term_definitions code="at0005">
                    <items id="text">Systemic complications</items>
                    <items id="description">Systemic complications occurring since implantation of this prosthesis.</items>
                    <items id="comment">If status is Present, at least one systemic complication should be recorded.

If status is None known, no systemic complication should be recorded.

Record each selected complication as a separate Systemic complication instance.

If Other is selected, Other systemic complication description should be recorded.

Record the complication date when available.</items>
                </term_definitions>
                <term_definitions code="at0006">
                    <items id="text">Local complications</items>
                    <items id="description">Local complications occurring since implantation of this prosthesis.</items>
                    <items id="comment">If status is Present, at least one local complication should be recorded.

If status is None known, no local complication should be recorded.

Record each selected complication as a separate Local complication instance.

If Other is selected, Other local complication description should be recorded.

Record the complication date or year when available.</items>
                </term_definitions>
                <term_definitions code="at0007">
                    <items id="text">Other associated orthopaedic conditions</items>
                    <items id="description">Other associated orthopaedic pathologies or conditions relevant to this clinical follow-up.</items>
                    <items id="comment">If status is Present, at least one associated orthopaedic condition should be recorded.

If status is None known, no associated orthopaedic condition should be recorded.

Record each selected condition as a separate Other associated orthopaedic condition instance.

Record laterality, date or year, and description when applicable.</items>
                </term_definitions>
                <term_definitions code="at0008">
                    <items id="text">Other known condition status</items>
                    <items id="description">Status indicating whether other known conditions are recorded at this follow-up.</items>
                    <items id="comment">Use when the presence of other known conditions is unknown or was not assessed.</items>
                </term_definitions>
                <term_definitions code="at0009">
                    <items id="text">Other known condition</items>
                    <items id="description">Category or specific type of other known condition recorded at clinical follow-up.</items>
                    <items id="comment">Repeatable element for multiselect use. Record each selected option as a separate instance. Do not record a value when the status is None known.</items>
                </term_definitions>
                <term_definitions code="at0010">
                    <items id="text">Other known condition description</items>
                    <items id="description">Free-text description of another known condition not represented by the coded options.</items>
                    <items id="comment">Use when Other is selected, or to provide additional clarification about a selected condition.</items>
                </term_definitions>
                <term_definitions code="at0011">
                    <items id="text">Comment</items>
                    <items id="description">Additional free-text comment about the orthopaedic clinical follow-up.</items>
                </term_definitions>
                <term_definitions code="at0015">
                    <items id="text">None known</items>
                    <items id="description">No other known conditions are recorded at this follow-up.</items>
                </term_definitions>
                <term_definitions code="at0016">
                    <items id="text">Present</items>
                    <items id="description">One or more other known conditions are recorded.</items>
                </term_definitions>
                <term_definitions code="at0017">
                    <items id="text">Unknown or not assessed</items>
                    <items id="description">It is unknown or was not assessed whether other conditions are present.</items>
                </term_definitions>
                <term_definitions code="at0018">
                    <items id="text">Nervous system</items>
                    <items id="description">Known condition related to the nervous system.</items>
                </term_definitions>
                <term_definitions code="at0019">
                    <items id="text">Gastrointestinal system</items>
                    <items id="description">Known condition related to the gastrointestinal system.</items>
                </term_definitions>
                <term_definitions code="at0020">
                    <items id="text">Osteoporosis</items>
                    <items id="description">Known osteoporosis.</items>
                </term_definitions>
                <term_definitions code="at0021">
                    <items id="text">Respiratory tract</items>
                    <items id="description">Known condition related to the respiratory tract.</items>
                </term_definitions>
                <term_definitions code="at0022">
                    <items id="text">Urogenital system</items>
                    <items id="description">Known condition related to the urogenital system.</items>
                </term_definitions>
                <term_definitions code="at0023">
                    <items id="text">Endocrine system</items>
                    <items id="description">Known condition related to the endocrine system.</items>
                </term_definitions>
                <term_definitions code="at0024">
                    <items id="text">Cardiovascular system</items>
                    <items id="description">Known condition related to the cardiovascular system.</items>
                </term_definitions>
                <term_definitions code="at0025">
                    <items id="text">Diabetes</items>
                    <items id="description">Known diabetes mellitus.</items>
                </term_definitions>
                <term_definitions code="at0026">
                    <items id="text">Other</items>
                    <items id="description">Other known condition not represented by the listed options.</items>
                </term_definitions>
                <term_definitions code="at0027">
                    <items id="text">Systemic complication status</items>
                    <items id="description">Status indicating whether systemic complications are recorded since prosthesis implantation.</items>
                    <items id="comment">Use Present when one or more systemic complications are recorded. Use None known only when no systemic complications are recorded. Use Unknown or not assessed when this information is unavailable or was not assessed.</items>
                </term_definitions>
                <term_definitions code="at0028">
                    <items id="text">None known</items>
                    <items id="description">No systemic complications are recorded since prosthesis implantation.</items>
                </term_definitions>
                <term_definitions code="at0029">
                    <items id="text">Present</items>
                    <items id="description">One or more systemic complications are recorded since prosthesis implantation.</items>
                </term_definitions>
                <term_definitions code="at0030">
                    <items id="text">Unknown or not assessed</items>
                    <items id="description">It is unknown or was not assessed whether systemic complications occurred.</items>
                </term_definitions>
                <term_definitions code="at0032">
                    <items id="text">Systemic complication</items>
                    <items id="description">Single systemic complication recorded since implantation of this prosthesis.</items>
                    <items id="comment">Repeatable cluster for multiselect use. Record each selected complication as a separate instance, with its date when available.</items>
                </term_definitions>
                <term_definitions code="at0034">
                    <items id="text">Systemic complication type</items>
                    <items id="description">Category or specific type of systemic complication recorded since prosthesis implantation.</items>
                    <items id="comment">Use one coded value for each systemic complication instance. Use Other when the complication is not represented by the listed options.</items>
                </term_definitions>
                <term_definitions code="at0035">
                    <items id="text">Pulmonary embolism</items>
                    <items id="description">Pulmonary embolism occurring since prosthesis implantation.</items>
                </term_definitions>
                <term_definitions code="at0036">
                    <items id="text">Thrombophlebitis</items>
                    <items id="description">Thrombophlebitis occurring since prosthesis implantation.</items>
                </term_definitions>
                <term_definitions code="at0037">
                    <items id="text">Central nervous system</items>
                    <items id="description">Systemic complication related to the central nervous system.</items>
                </term_definitions>
                <term_definitions code="at0038">
                    <items id="text">Respiratory tract</items>
                    <items id="description">Systemic complication related to the respiratory tract.</items>
                </term_definitions>
                <term_definitions code="at0039">
                    <items id="text">Cardiovascular system</items>
                    <items id="description">Systemic complication related to the cardiovascular system.</items>
                </term_definitions>
                <term_definitions code="at0040">
                    <items id="text">Urological system</items>
                    <items id="description">Systemic complication related to the urinary or urological system.</items>
                </term_definitions>
                <term_definitions code="at0041">
                    <items id="text">Gastrointestinal system</items>
                    <items id="description">Systemic complication related to the gastrointestinal system.</items>
                </term_definitions>
                <term_definitions code="at0042">
                    <items id="text">Other</items>
                    <items id="description">Other systemic complication not represented by the listed options.</items>
                </term_definitions>
                <term_definitions code="at0044">
                    <items id="text">Complication date</items>
                    <items id="description">Date when the systemic complication occurred or was identified.</items>
                    <items id="comment">Record the date next to the systemic complication when available.</items>
                </term_definitions>
                <term_definitions code="at0045">
                    <items id="text">Other systemic complication description</items>
                    <items id="description">Free-text description of a systemic complication not represented by the coded options.</items>
                    <items id="comment">Use when Other is selected, or to provide additional clarification about a selected systemic complication.</items>
                </term_definitions>
                <term_definitions code="at0046">
                    <items id="text">Local complication status</items>
                    <items id="description">Status indicating whether local complications are recorded since prosthesis implantation.</items>
                    <items id="comment">Use Present when one or more local complications are recorded. Use None known only when no local complications are recorded. Use Unknown or not assessed when this information is unavailable or was not assessed.</items>
                </term_definitions>
                <term_definitions code="at0047">
                    <items id="text">None known</items>
                    <items id="description">No local complications are recorded since prosthesis implantation.</items>
                </term_definitions>
                <term_definitions code="at0048">
                    <items id="text">Present</items>
                    <items id="description">One or more local complications are recorded since prosthesis implantation.</items>
                </term_definitions>
                <term_definitions code="at0049">
                    <items id="text">Unknown or not assessed</items>
                    <items id="description">It is unknown or was not assessed whether local complications occurred.</items>
                </term_definitions>
                <term_definitions code="at0050">
                    <items id="text">Local complication</items>
                    <items id="description">Single local complication recorded since implantation of this prosthesis.</items>
                    <items id="comment">Repeatable cluster for multiselect use. Record each selected complication as a separate instance, with its date or year when available.</items>
                </term_definitions>
                <term_definitions code="at0051">
                    <items id="text">Local complication type</items>
                    <items id="description">Category or specific type of local complication recorded since prosthesis implantation.</items>
                    <items id="comment">Use one coded value for each local complication instance. Use Other when the complication is not represented by the listed options.</items>
                </term_definitions>
                <term_definitions code="at0052">
                    <items id="text">Dislocation</items>
                    <items id="description">Local dislocation occurring since prosthesis implantation.</items>
                </term_definitions>
                <term_definitions code="at0053">
                    <items id="text">Haematoma / seroma</items>
                    <items id="description">Local haematoma or seroma occurring since prosthesis implantation.</items>
                </term_definitions>
                <term_definitions code="at0054">
                    <items id="text">Persistent drainage</items>
                    <items id="description">Persistent wound drainage occurring since prosthesis implantation.</items>
                </term_definitions>
                <term_definitions code="at0055">
                    <items id="text">Dehiscence</items>
                    <items id="description">Wound dehiscence occurring since prosthesis implantation.</items>
                </term_definitions>
                <term_definitions code="at0056">
                    <items id="text">Neuropraxia</items>
                    <items id="description">Local neuropraxia occurring since prosthesis implantation.</items>
                </term_definitions>
                <term_definitions code="at0057">
                    <items id="text">Loosening</items>
                    <items id="description">Prosthesis loosening occurring since implantation.</items>
                </term_definitions>
                <term_definitions code="at0058">
                    <items id="text">Deep sepsis</items>
                    <items id="description">Deep sepsis or deep infection occurring since prosthesis implantation.</items>
                </term_definitions>
                <term_definitions code="at0059">
                    <items id="text">Superficial sepsis</items>
                    <items id="description">Superficial sepsis or superficial infection occurring since prosthesis implantation.</items>
                </term_definitions>
                <term_definitions code="at0060">
                    <items id="text">Other</items>
                    <items id="description">Other local complication not represented by the listed options.</items>
                </term_definitions>
                <term_definitions code="at0061">
                    <items id="text">Complication date</items>
                    <items id="description">Date or year when the local complication occurred or was identified.</items>
                    <items id="comment">Record the date or year next to the complication when available.</items>
                </term_definitions>
                <term_definitions code="at0062">
                    <items id="text">Other local complication description</items>
                    <items id="description">Free-text description of a local complication not represented by the coded options.</items>
                    <items id="comment">Use when Other is selected, or to provide additional clarification about a selected local complication.</items>
                </term_definitions>
                <term_definitions code="at0063">
                    <items id="text">Other associated orthopaedic condition status</items>
                    <items id="description">Status indicating whether other associated orthopaedic conditions are recorded at this follow-up.</items>
                    <items id="comment">Use Present when one or more associated orthopaedic conditions are recorded. Use None known only when no associated orthopaedic conditions are recorded. Use Unknown or not assessed when this information is unavailable or was not assessed.</items>
                </term_definitions>
                <term_definitions code="at0064">
                    <items id="text">None known</items>
                    <items id="description">No other associated orthopaedic conditions are recorded at this follow-up.</items>
                </term_definitions>
                <term_definitions code="at0065">
                    <items id="text">Present</items>
                    <items id="description">One or more other associated orthopaedic conditions are recorded at this follow-up.</items>
                </term_definitions>
                <term_definitions code="at0066">
                    <items id="text">Unknown or not assessed</items>
                    <items id="description">It is unknown or was not assessed whether other associated orthopaedic conditions are present.</items>
                </term_definitions>
                <term_definitions code="at0067">
                    <items id="text">Other associated orthopaedic condition</items>
                    <items id="description">Single other associated orthopaedic condition recorded at this follow-up.</items>
                    <items id="comment">Repeatable cluster for multiselect use. Record each selected condition as a separate instance, with laterality, date or year, and description when applicable.</items>
                </term_definitions>
                <term_definitions code="at0069">
                    <items id="text">Other associated orthopaedic condition type</items>
                    <items id="description">Category or specific type of other associated orthopaedic condition recorded at clinical follow-up.</items>
                    <items id="comment">Use one coded value for each associated orthopaedic condition instance. Use Other when the condition is not represented by the listed options.</items>
                </term_definitions>
                <term_definitions code="at0070">
                    <items id="text">Contralateral knee</items>
                    <items id="description">Associated condition affecting the contralateral knee.</items>
                </term_definitions>
                <term_definitions code="at0071">
                    <items id="text">Ankle / foot</items>
                    <items id="description">Associated condition affecting the ankle or foot.</items>
                </term_definitions>
                <term_definitions code="at0072">
                    <items id="text">Wrist / hand</items>
                    <items id="description">Associated condition affecting the wrist or hand.</items>
                </term_definitions>
                <term_definitions code="at0073">
                    <items id="text">Opposite hip</items>
                    <items id="description">Associated condition affecting the opposite hip.</items>
                </term_definitions>
                <term_definitions code="at0074">
                    <items id="text">Shoulder</items>
                    <items id="description">Associated condition affecting the shoulder.</items>
                </term_definitions>
                <term_definitions code="at0075">
                    <items id="text">Trauma</items>
                    <items id="description">Associated orthopaedic condition related to trauma.</items>
                </term_definitions>
                <term_definitions code="at0076">
                    <items id="text">Spine</items>
                    <items id="description">Associated condition affecting the spine.</items>
                </term_definitions>
                <term_definitions code="at0077">
                    <items id="text">Elbow</items>
                    <items id="description">Associated condition affecting the elbow.</items>
                </term_definitions>
                <term_definitions code="at0078">
                    <items id="text">Other</items>
                    <items id="description">Other associated orthopaedic condition not represented by the listed options.</items>
                </term_definitions>
                <term_definitions code="at0079">
                    <items id="text">Condition date</items>
                    <items id="description">Date or year when the associated orthopaedic condition occurred or was identified.</items>
                    <items id="comment">Record the date or year next to the associated orthopaedic condition when available.</items>
                </term_definitions>
                <term_definitions code="at0080">
                    <items id="text">Condition laterality</items>
                    <items id="description">Laterality of the associated orthopaedic condition, where applicable.</items>
                    <items id="comment">Record for contralateral knee or opposite hip when applicable, using the anatomical side affected.</items>
                </term_definitions>
                <term_definitions code="at0081">
                    <items id="text">Left</items>
                    <items id="description">Left side.</items>
                </term_definitions>
                <term_definitions code="at0082">
                    <items id="text">Right</items>
                    <items id="description">Right side.</items>
                </term_definitions>
                <term_definitions code="at0084">
                    <items id="text">Bilateral</items>
                    <items id="description">Both left and right sides.</items>
                </term_definitions>
                <term_definitions code="at0085">
                    <items id="text">Other associated orthopaedic condition description</items>
                    <items id="description">Free-text description of the associated orthopaedic condition.</items>
                    <items id="comment">Use when Trauma or Other is selected, or to provide additional clarification about a selected associated orthopaedic condition.</items>
                </term_definitions>
                <term_definitions code="at0086">
                    <items id="text">Unknown</items>
                    <items id="description">Laterality is unknown.</items>
                </term_definitions>
            </children>
