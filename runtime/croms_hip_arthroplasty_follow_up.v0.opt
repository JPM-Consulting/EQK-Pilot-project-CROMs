                <items id="description"></items>
            </items>
            <items code="at0036">
                <items id="text">Non</items>
                <items id="description">Le critère n’est pas rempli.</items>
            </items>
            <items code="at0037">
                <items id="text">Oui</items>
                <items id="description">Le critère est rempli.</items>
            </items>
            <items code="at0038">
                <items id="text">Inconnu ou non évalué</items>
                <items id="description">Il est inconnu ou non évalué si le critère est rempli.</items>
            </items>
            <items code="at0039">
                <items id="text">Statut de la position asymétrique de la tête</items>
                <items id="description">Évaluation radiographique de la position asymétrique de la tête fémorale dans la cupule acétabulaire.</items>
            </items>
            <items code="at0040">
                <items id="text">Non</items>
                <items id="description">La constatation n’est pas présente.</items>
            </items>
            <items code="at0041">
                <items id="text">Oui</items>
                <items id="description">La constatation est présente.</items>
            </items>
            <items code="at0042">
                <items id="text">Inconnu ou non évalué</items>
                <items id="description">Il est inconnu ou non évalué si la constatation est présente.</items>
            </items>
            <items code="at0043">
                <items id="text">Zone du cotyle</items>
                <items id="description">Zone acétabulaire de DeLee-Charnley concernée par la position asymétrique de la tête.</items>
                <items id="comment">Élément répétable pour une utilisation en sélection multiple. Enregistrer chaque zone DeLee-Charnley sélectionnée comme une instance distincte.</items>
            </items>
            <items code="at0044">
                <items id="text">Zone DeLee-Charnley 1</items>
                <items id="description"></items>
