                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0005">
                    <items id="text">Prosthesis site</items>
                    <items id="description">Anatomical site and side to which the hip prosthesis X-ray follow-up findings apply.</items>
                </term_definitions>
                <term_definitions code="at0006">
                    <items id="text">Body site</items>
                    <items id="description">Hip region or hip joint to which the prosthesis follow-up findings apply.</items>
                </term_definitions>
