                <archetype_id>
                    <value>openEHR-EHR-OBSERVATION.orthopaedic_hip_clinical_follow_up.v0</value>
                </archetype_id>
                <term_definitions code="at0000">
                    <items id="text">Hip clinical follow-up including HHS</items>
                    <items id="description">A structured clinician-reported assessment of hip function and clinical outcome before or after hip arthroplasty or hip surgery, including optional recording of Harris Hip Score items and total score.</items>
                </term_definitions>
                <term_definitions code="at0001">
                    <items id="text">History</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0002">
                    <items id="text">Point in time</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0003">
                    <items id="text">Tree</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0004">
                    <items id="text">Item tree</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0005">
                    <items id="text">Consulting clinician name</items>
                    <items id="description">Name of the clinician responsible for, or performing, the clinical follow-up assessment, as recorded on the form.</items>
                </term_definitions>
                <term_definitions code="at0006">
                    <items id="text">Follow-up timing</items>
                    <items id="description">Timing of the follow-up assessment in relation to surgery, baseline assessment or the planned follow-up schedule.</items>
                </term_definitions>
                <term_definitions code="at0007">
                    <items id="text">Preoperative</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0008">
                    <items id="text">6 weeks</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0009">
                    <items id="text">3 months</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0010">
                    <items id="text">6 months</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0011">
                    <items id="text">1 year</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0012">
                    <items id="text">2 years</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0013">
                    <items id="text">Other number of years</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0014">
                    <items id="text">Other follow-up interval in years</items>
                    <items id="description">Number of years after surgery or baseline assessment for the follow-up timing, used when 'Other number of years' is selected.</items>
                </term_definitions>
                <term_definitions code="at0015">
                    <items id="text">Hip arthroplasty context</items>
                    <items id="description">Contextual information about the hip arthroplasty or hip prosthesis relevant to this clinical follow-up assessment.</items>
                </term_definitions>
                <term_definitions code="at0028">
                    <items id="text">Side operated or to be operated</items>
                    <items id="description">Laterality of the hip being assessed, including the hip that has been operated on or is planned for operation.</items>
                </term_definitions>
                <term_definitions code="at0029">
                    <items id="text">Right</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0030">
                    <items id="text">Left</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0031">
                    <items id="text">Prosthesis summary</items>
                    <items id="description">Summary information about the hip prosthesis components relevant to the follow-up assessment. This is not intended as the primary implant registry or device documentation.</items>
                </term_definitions>
                <term_definitions code="at0032">
                    <items id="text">Cup / acetabular component</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0033">
                    <items id="text">Head</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0034">
                    <items id="text">Stem</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0036">
                    <items id="text">Pain assessment</items>
                    <items id="description">Assessment of pain severity and pain location related to the assessed hip.</items>
                </term_definitions>
                <term_definitions code="at0037">
                    <items id="text">Functional assessment</items>
                    <items id="description">Assessment of functional limitations related to the assessed hip, including gait, use of walking aids, walking distance, stair climbing, sitting, use of public transport and selected activities of daily living.</items>
                </term_definitions>
                <term_definitions code="at0038">
                    <items id="text">Deformity assessment</items>
                    <items id="description">Assessment of deformity criteria of the assessed hip relevant to the Harris Hip Score, including fixed deformities and limb length discrepancy.</items>
                </term_definitions>
                <term_definitions code="at0039">
                    <items id="text">Range of motion</items>
                    <items id="description">Assessment of the range of motion of the assessed hip, including flexion, extension, abduction, adduction, external rotation and internal rotation.</items>
                </term_definitions>
                <term_definitions code="at0040">
                    <items id="text">Limb length assessment</items>
                    <items id="description">Assessment of the length of the operated or assessed limb compared with the contralateral limb.</items>
                </term_definitions>
                <term_definitions code="at0041">
                    <items id="text">Physical condition</items>
                    <items id="description">Clinical assessment of the patient's overall physical condition in relation to age.</items>
                </term_definitions>
                <term_definitions code="at0042">
                    <items id="text">Score summary</items>
                    <items id="description">Summary of calculated or recorded score results for the hip clinical follow-up assessment, including Harris Hip Score and, where applicable, modified Harris Hip Score totals and grading.</items>
                </term_definitions>
                <term_definitions code="at0043">
                    <items id="text">Pain</items>
                    <items id="description">Severity or impact of pain related to the assessed hip.</items>
                </term_definitions>
                <term_definitions code="at0044">
                    <items id="text">None, or ignores it</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0045">
                    <items id="text">Slight, occasional, no compromise in activity</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0046">
                    <items id="text">Mild pain, no effect on average activities, rarely moderate pain with unusual activity, may take aspirin</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0047">
                    <items id="text">Moderate pain, tolerable but makes concessions to pain. Some limitations of ordinary activity or work. May require occasional pain medication stronger than aspirin</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0048">
                    <items id="text">Marked pain, serious limitation of activities</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0049">
                    <items id="text">Totally disabled, crippled, pain in bed, bedridden</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0050">
                    <items id="text">Pain location</items>
                    <items id="description">Anatomical location of pain related to the assessed hip. Multiple locations may be recorded.</items>
                    <items id="comment">Supplementary question regarding HHS.</items>
                </term_definitions>
                <term_definitions code="at0051">
                    <items id="text">Groin</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0052">
                    <items id="text">Anterior thigh</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0053">
                    <items id="text">Lateral thigh</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0054">
                    <items id="text">Trochanter</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0055">
                    <items id="text">Knee</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0056">
                    <items id="text">Lumbar / lower back</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0057">
                    <items id="text">Sacroiliac</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0058">
                    <items id="text">Other</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0059">
                    <items id="text">Other pain location</items>
                    <items id="description">Narrative description of another pain location, used when 'Other' is selected.</items>
                    <items id="comment">Supplementary question regarding HHS.</items>
                </term_definitions>
                <term_definitions code="at0060">
                    <items id="text">Limp</items>
                    <items id="description">Degree of limping during walking.</items>
                </term_definitions>
                <term_definitions code="at0061">
                    <items id="text">None</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0062">
                    <items id="text">Slight</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0063">
                    <items id="text">Moderate</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0064">
                    <items id="text">Severe</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0065">
                    <items id="text">Support devices</items>
                    <items id="description">Use of walking aids or support devices for ambulation.</items>
                </term_definitions>
                <term_definitions code="at0066">
                    <items id="text">None</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0067">
                    <items id="text">Cane/walking stick for long walks</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0068">
                    <items id="text">Cane/walking stick most of the time</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0069">
                    <items id="text">One crutch</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0070">
                    <items id="text">Two canes/walking sticks</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0071">
                    <items id="text">Two crutches or not able to walk</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0072">
                    <items id="text">Distance walked</items>
                    <items id="description">Maximum walking distance or walking capacity.</items>
                </term_definitions>
                <term_definitions code="at0073">
                    <items id="text">Unlimited</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0074">
                    <items id="text">Six blocks</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0075">
                    <items id="text">Two or three blocks</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0076">
                    <items id="text">Indoors only</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0077">
                    <items id="text">Bed and chair only</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0078">
                    <items id="text">Stairs</items>
                    <items id="description">Ability to climb or descend stairs.</items>
                </term_definitions>
                <term_definitions code="at0079">
                    <items id="text">Normally without using a railing</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0080">
                    <items id="text">Normally using a railing</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0081">
                    <items id="text">In any manner</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0082">
                    <items id="text">Unable to do stairs</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0083">
                    <items id="text">Shoes and socks</items>
                    <items id="description">Ability to put on shoes and socks.</items>
                </term_definitions>
                <term_definitions code="at0084">
                    <items id="text">With ease</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0085">
                    <items id="text">With difficulty</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0086">
                    <items id="text">Unable</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0087">
                    <items id="text">Sitting</items>
                    <items id="description">Ability to sit comfortably on a chair for a defined duration.</items>
                </term_definitions>
                <term_definitions code="at0088">
                    <items id="text">Comfortably in ordinary chair for one hour</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0089">
                    <items id="text">On a high chair for 30 minutes</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0090">
                    <items id="text">Unable to sit comfortably in any chair</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0091">
                    <items id="text">Public transportation</items>
                    <items id="description">Ability to use public transportation.</items>
                </term_definitions>
                <term_definitions code="at0092">
                    <items id="text">Able to use transportation (bus)</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0093">
                    <items id="text">Unable to use public transportation (bus)</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0094">
                    <items id="text">Single-leg stance</items>
                    <items id="description">Supplementary assessment of the patient's ability to stand on the assessed leg.</items>
                    <items id="comment">Supplementary question regarding HHS.</items>
                </term_definitions>
                <term_definitions code="at0095">
                    <items id="text">No difficulty</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0096">
                    <items id="text">Minor difficulty</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0097">
                    <items id="text">Major difficulty</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0098">
                    <items id="text">Impossible</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0104">
                    <items id="text">Flexion</items>
                    <items id="description">Range of hip flexion measured in degrees.</items>
                </term_definitions>
                <term_definitions code="at0105">
                    <items id="text">Extension</items>
                    <items id="description">Range of hip extension measured in degrees.</items>
                </term_definitions>
                <term_definitions code="at0106">
                    <items id="text">Abduction</items>
                    <items id="description">Range of hip abduction measured in degrees.</items>
                </term_definitions>
                <term_definitions code="at0107">
                    <items id="text">Adduction</items>
                    <items id="description">Range of hip adduction measured in degrees.</items>
                </term_definitions>
                <term_definitions code="at0108">
                    <items id="text">External rotation</items>
                    <items id="description">Range of hip external rotation measured in degrees.</items>
                </term_definitions>
                <term_definitions code="at0109">
                    <items id="text">Internal rotation</items>
                    <items id="description">Range of hip internal rotation measured in degrees.</items>
                </term_definitions>
                <term_definitions code="at0110">
                    <items id="text">Operated limb length compared with the other limb</items>
                    <items id="description">Qualitative comparison of the length of the operated or assessed limb with the contralateral limb.</items>
                    <items id="comment">Supplementary question regarding HHS.</items>
                </term_definitions>
                <term_definitions code="at0111">
                    <items id="text">Same</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0112">
                    <items id="text">Longer</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0113">
                    <items id="text">Shorter</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0114">
                    <items id="text">Limb length difference (mm)</items>
                    <items id="description">Measured or estimated difference in length between the operated or assessed limb and the contralateral limb, recorded in millimetres.</items>
                    <items id="comment">Supplementary question regarding HHS.</items>
                </term_definitions>
                <term_definitions code="at0115">
                    <items id="text">Physical condition relative to age</items>
                    <items id="description">Overall physical condition of the patient compared with the expected physical condition for their age. This is a supplementary item recorded in addition to the Harris Hip Score.</items>
                    <items id="comment">Supplementary question regarding HHS.</items>
                </term_definitions>
                <term_definitions code="at0116">
                    <items id="text">Excellent</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0117">
                    <items id="text">Good</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0118">
                    <items id="text">Average</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0119">
                    <items id="text">Poor</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0120">
                    <items id="text">HHS total</items>
                    <items id="description">Total Harris Hip Score, recorded as the sum of points from the assessment.</items>
                </term_definitions>
                <term_definitions code="at0121">
                    <items id="text">mHHS raw total</items>
                    <items id="description">Raw total score for the modified Harris Hip Score, recorded as the sum of points from the modified assessment.</items>
                </term_definitions>
                <term_definitions code="at0122">
                    <items id="text">mHHS normalised total</items>
                    <items id="description">Normalised modified Harris Hip Score, representing the raw score expressed on a 0–100 scale for comparability with the original Harris Hip Score.</items>
                </term_definitions>
                <term_definitions code="at0123">
                    <items id="text">Grading</items>
                    <items id="description">Categorical grading derived from the Harris Hip Score total.</items>
                </term_definitions>
                <term_definitions code="at0124">
                    <items id="text">Poor</items>
                    <items id="description">Less than 70.</items>
                </term_definitions>
                <term_definitions code="at0125">
                    <items id="text">Fair</items>
                    <items id="description">70-79.</items>
                </term_definitions>
                <term_definitions code="at0126">
                    <items id="text">Good</items>
                    <items id="description">80-89.</items>
                </term_definitions>
                <term_definitions code="at0127">
                    <items id="text">Excellent</items>
                    <items id="description">90-100.</items>
                </term_definitions>
                <term_definitions code="at0128">
                    <items id="text">Absence of deformity</items>
                    <items id="description">Score component indicating whether all criteria for absence of deformity are met: less than 30 degrees of fixed flexion contracture, less than 10 degrees of fixed internal rotation in extension, less than 10 degrees of fixed adduction, and limb length discrepancy less than 3.2 cm.</items>
                </term_definitions>
                <term_definitions code="at0129">
                    <items id="text">One or more criteria are not met.</items>
                    <items id="description">One or more criteria for absence of deformity are not met.</items>
                </term_definitions>
                <term_definitions code="at0130">
                    <items id="text">All four criteria are met.</items>
                    <items id="description">All four criteria for absence of deformity are met.</items>
                </term_definitions>
                <term_definitions code="at0131">
                    <items id="text">Activity</items>
                    <items id="description">Supplementary assessment of the patient's activity level or independence in activity, recorded in addition to the Harris Hip Score items.</items>
                    <items id="comment">Supplementary question regarding HHS.</items>
                </term_definitions>
                <term_definitions code="at0132">
                    <items id="text">Significant / high</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0133">
                    <items id="text">Daily</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0134">
                    <items id="text">Independent</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0135">
                    <items id="text">Not independent</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0136">
                    <items id="text">No fixed adduction ≥ 10°</items>
                    <items id="description">Indicates whether there is no fixed adduction deformity of 10 degrees or more. A value of true means that this criterion for absence of deformity is met.</items>
                    <items id="comment">Supplementary question regarding HHS.</items>
                </term_definitions>
                <term_definitions code="at0137">
                    <items id="text">No fixed internal rotation ≥ 10°</items>
                    <items id="description">Indicates whether there is no fixed internal rotation deformity of 10 degrees or more. A value of true means that this criterion for absence of deformity is met.</items>
                    <items id="comment">Supplementary question regarding HHS.</items>
                </term_definitions>
                <term_definitions code="at0138">
                    <items id="text">No limb length difference ≥ 3.2 cm</items>
                    <items id="description">Indicates whether there is no limb length difference of 3.2 cm or more. A value of true means that this criterion for absence of deformity is met.</items>
                    <items id="comment">Supplementary question regarding HHS.</items>
                </term_definitions>
                <term_definitions code="at0139">
                    <items id="text">No fixed flexion contracture ≥ 30°</items>
                    <items id="description">Indicates whether there is no fixed flexion contracture of 30 degrees or more. A value of true means that this criterion for absence of deformity is met.</items>
                    <items id="comment">Supplementary question regarding HHS.</items>
                </term_definitions>
                <term_definitions code="at0140">
                    <items id="text">Total range of motion score</items>
                    <items id="description">Ordinal score component derived from the categorised total range of motion of the assessed hip.</items>
                </term_definitions>
                <term_definitions code="at0141">
                    <items id="text">211°–300°</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0142">
                    <items id="text">161°–210°</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0143">
                    <items id="text">101°–160°</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0144">
                    <items id="text">61°–100°</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0145">
                    <items id="text">31°–60°</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0146">
                    <items id="text">0°–30°</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="deg">
                    <items id="text">°</items>
                    <items id="description">degree</items>
                </term_definitions>
            </children>
