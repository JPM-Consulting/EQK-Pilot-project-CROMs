                <term_definitions code="at0000">
                    <items id="text">Hip prosthesis X-ray follow-up</items>
                    <items id="description">Structured radiographic follow-up findings for a hip prosthesis, including cup, stem, radiolucency, ossification and angular measurements.</items>
                </term_definitions>
                <term_definitions code="at0001">
                    <items id="text">History</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0002">
                    <items id="text">Point in time</items>
                    <items id="description">@ internal @</items>
