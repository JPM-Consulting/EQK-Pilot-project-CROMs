    <component_ontologies archetype_id="openEHR-EHR-OBSERVATION.hip_prosthesis_xray_follow_up.v0">
        <term_definitions language="fr">
            <items code="at0000">
                <items id="text">Suivi radiographique de prothèse de hanche</items>
                <items id="description">Constatations radiographiques structurées de suivi d’une prothèse de hanche, incluant le cotyle, la tige, les lignes radiotransparentes, l’ossification et les mesures angulaires.</items>
            </items>
            <items code="at0001">
                <items id="text">Historique</items>
                <items id="description">@ internal @</items>
            </items>
            <items code="at0002">
                <items id="text">Tout événement</items>
                <items id="description">@ internal @</items>
            </items>
            <items code="at0003">
                <items id="text">Arborescence</items>
                <items id="description">@ internal @</items>
            </items>
            <items code="at0004">
                <items id="text">Arborescence des éléments</items>
                <items id="description">@ internal @</items>
            </items>
            <items code="at0005">
                <items id="text">Site de la prothèse</items>
                <items id="description">Site anatomique et côté auxquels s’appliquent les constatations du suivi radiographique de la prothèse de hanche.</items>
            </items>
            <items code="at0006">
                <items id="text">Site anatomique</items>
                <items id="description">Région de la hanche ou articulation de la hanche à laquelle s’appliquent les constatations de suivi de la prothèse.</items>
            </items>
            <items code="at0007">
                <items id="text">Hanche</items>
                <items id="description"></items>
            </items>
            <items code="at0008">
                <items id="text">Latéralité</items>
                <items id="description">Côté de la prothèse de hanche auquel s’appliquent les constatations du suivi radiographique.</items>
            </items>
            <items code="at0009">
                <items id="text">Gauche</items>
                <items id="description">Côté gauche.</items>
            </items>
            <items code="at0010">
                <items id="text">Droit</items>
                <items id="description">Côté droit.</items>
            </items>
            <items code="at0013">
                <items id="text">Constatations du suivi radiographique de la prothèse de hanche</items>
                <items id="description">Constatations radiographiques structurées issues du suivi radiographique d’une prothèse de hanche.</items>
                <items id="comment">Utiliser pour enregistrer les constatations structurées relatives au cotyle, à la tige, aux lignes radiotransparentes, à l’ossification hétérotopique et aux mesures angulaires issues du suivi radiographique.</items>
            </items>
            <items code="at0015">
                <items id="text">Date de mesure</items>
                <items id="description">Date à laquelle l’examen radiographique a été réalisé.</items>
                <items id="comment">Utiliser lorsque la date de l’examen radiographique diffère de la date ou de l’heure d’enregistrement des constatations structurées.</items>
            </items>
            <items code="at0016">
                <items id="text">Marque de la cupule</items>
                <items id="description">Nom commercial de la cupule acétabulaire, s’il est documenté.</items>
                <items id="comment">Utiliser lorsque la marque de la cupule est disponible dans la documentation clinique ou radiographique.</items>
            </items>
            <items code="at0018">
                <items id="text">Migration du cotyle</items>
                <items id="description">Évaluation radiographique de la migration du cotyle.</items>
                <items id="comment">Référence d’image [img].</items>
            </items>
            <items code="at0019">
                <items id="text">Position asymétrique de la tête</items>
                <items id="description">Évaluation radiographique de la position asymétrique de la tête fémorale dans la cupule acétabulaire.</items>
                <items id="comment">Référence d’image [img].</items>
            </items>
            <items code="at0020">
                <items id="text">Lignes radiotransparentes</items>
                <items id="description">Évaluation radiographique des lignes radiotransparentes autour de la cupule acétabulaire ou de la tige fémorale.</items>
                <items id="comment">Référence d’image [img].
Référence d’image [img].</items>
            </items>
            <items code="at0021">
                <items id="text">Enfoncement de la tige</items>
                <items id="description">Évaluation radiographique de l’enfoncement de la tige fémorale après implantation.</items>
            </items>
            <items code="at0022">
                <items id="text">Résorption du calcar</items>
                <items id="description">Évaluation radiographique de la résorption du calcar.</items>
            </items>
            <items code="at0023">
                <items id="text">Hypertrophie corticale</items>
                <items id="description">Évaluation radiographique de l’hypertrophie corticale autour de la tige fémorale.</items>
                <items id="comment">Référence d’image [img].</items>
            </items>
            <items code="at0024">
                <items id="text">Ossification hétérotopique</items>
                <items id="description">Évaluation radiographique de l’ossification hétérotopique autour de la hanche.</items>
            </items>
            <items code="at0025">
                <items id="text">Mesures du cotyle</items>
                <items id="description">Mesures angulaires de la cupule acétabulaire.</items>
            </items>
            <items code="at0026">
                <items id="text">Mesures du col fémoral</items>
                <items id="description">Mesures angulaires relatives au col fémoral ou au composant fémoral.</items>
            </items>
            <items code="at0027">
                <items id="text">Statut de la migration du cotyle</items>
                <items id="description">Statut indiquant si une migration du cotyle est présente.</items>
            </items>
            <items code="at0028">
                <items id="text">Non</items>
                <items id="description">La constatation n’est pas présente.</items>
            </items>
            <items code="at0029">
                <items id="text">Oui</items>
                <items id="description">La constatation est présente.</items>
            </items>
            <items code="at0030">
                <items id="text">Inconnu ou non évalué</items>
                <items id="description">Il est inconnu ou non évalué si la constatation est présente.</items>
            </items>
            <items code="at0031">
                <items id="text">Migration de plus de 3 mm</items>
                <items id="description"></items>
            </items>
            <items code="at0032">
