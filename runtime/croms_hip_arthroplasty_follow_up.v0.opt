                    <items id="description">Right side.</items>
                </term_definitions>
                <term_definitions code="at0013">
                    <items id="text">Hip prosthesis X-ray follow-up findings</items>
                    <items id="description">Structured radiographic findings from hip prosthesis X-ray follow-up.</items>
                    <items id="comment">Use to record structured cup, stem, radiolucency, heterotopic ossification and angular measurement findings from the X-ray follow-up.</items>
                </term_definitions>
                <term_definitions code="at0015">
                    <items id="text">X-ray examination date</items>
                    <items id="description">Date on which the X-ray examination was performed.</items>
                    <items id="comment">Use when the X-ray examination date differs from the date or time when the structured findings are recorded.</items>
                </term_definitions>
                <term_definitions code="at0016">
                    <items id="text">Cup brand name</items>
                    <items id="description">Brand name of the acetabular cup component, if recorded.</items>
                    <items id="comment">Use when the cup brand is available from the clinical or radiographic documentation.</items>
                </term_definitions>
                <term_definitions code="at0018">
                    <items id="text">Cup migration</items>
                    <items id="description">Radiographic assessment of acetabular cup migration.</items>
                    <items id="comment">Image-Reference [img].</items>
                </term_definitions>
                <term_definitions code="at0019">
                    <items id="text">Asymmetric head position</items>
                    <items id="description">Radiographic assessment of asymmetric femoral head position within the acetabular cup.</items>
                    <items id="comment">Image-Reference [img].</items>
                </term_definitions>
                <term_definitions code="at0020">
                    <items id="text">Radiolucent lines</items>
                    <items id="description">Radiographic assessment of radiolucent lines around the acetabular cup or femoral stem.</items>
